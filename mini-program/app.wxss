/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #333;
  background-color: #f5f7fa;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主题色变量 */
:root {
  --primary-color: #FF8C42;
  --primary-dark: #E67E22;
  --primary-light: #FFF7E6;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #FF4D4F;
  --info-color: #1890FF;
  --text-primary: #1f2329;
  --text-secondary: #646a73;
  --text-tertiary: #999;
  --border-color: #e8e9eb;
  --bg-primary: #f5f7fa;
  --bg-secondary: #fff;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: opacity 0.3s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  color: #fff;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-default {
  background: #fff;
  color: #666;
  border: 1rpx solid #e8e9eb;
}

.btn-danger {
  background: #FF4D4F;
  color: #fff;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-more {
  font-size: 26rpx;
  color: #999;
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.list-content {
  flex: 1;
}

.list-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.list-desc {
  font-size: 26rpx;
  color: #999;
}

.list-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 表单样式 */
.form-group {
  background: #fff;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #333;
}

.form-label.required::before {
  content: '*';
  color: #FF4D4F;
  margin-right: 8rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.form-input::placeholder {
  color: #ccc;
}

.form-textarea {
  flex: 1;
  height: 200rpx;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: #FFF7E6;
  color: #FF8C42;
}

.tag-success {
  background: #E6F7E6;
  color: #52C41A;
}

.tag-warning {
  background: #FFF7E6;
  color: #FAAD14;
}

.tag-error {
  background: #FFE5E5;
  color: #FF4D4F;
}

.tag-info {
  background: #E6F4FF;
  color: #1890FF;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 加载样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF8C42;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.empty-btn {
  margin-top: 40rpx;
  padding: 16rpx 40rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
