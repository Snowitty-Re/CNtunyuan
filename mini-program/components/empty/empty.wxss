.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-wrapper.hide {
  display: none;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon .iconfont {
  font-size: 80rpx;
  color: #ccc;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-button {
  padding: 16rpx 48rpx;
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: none;
}

.empty-button::after {
  border: none;
}
