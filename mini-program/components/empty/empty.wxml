<view class="empty-wrapper {{show ? 'show' : 'hide'}}">
  <image class="empty-image" src="{{image}}" mode="aspectFit" wx:if="{{image}}" />
  <view class="empty-icon" wx:else>
    <text class="iconfont icon-empty"></text>
  </view>
  <text class="empty-text">{{text}}</text>
  <text class="empty-subtext" wx:if="{{subText}}">{{subText}}</text>
  <button 
    class="empty-button" 
    wx:if="{{buttonText}}" 
    bindtap="onButtonTap"
  >{{buttonText}}</button>
</view>
