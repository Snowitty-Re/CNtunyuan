.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-wrapper.full-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  padding: 0;
}

.loading-wrapper.hide {
  display: none;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 默认样式 */
.spinner-default {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 圆圈样式 */
.spinner-circle {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.circle-item {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.circle-item::before {
  content: '';
  display: block;
  width: 10rpx;
  height: 10rpx;
  background: #1890ff;
  border-radius: 50%;
  margin: 0 auto;
  animation: circleFade 1.2s ease-in-out infinite both;
}

.circle-item:nth-child(1) { transform: rotate(30deg); }
.circle-item:nth-child(2) { transform: rotate(60deg); }
.circle-item:nth-child(3) { transform: rotate(90deg); }
.circle-item:nth-child(4) { transform: rotate(120deg); }
.circle-item:nth-child(5) { transform: rotate(150deg); }
.circle-item:nth-child(6) { transform: rotate(180deg); }
.circle-item:nth-child(7) { transform: rotate(210deg); }
.circle-item:nth-child(8) { transform: rotate(240deg); }
.circle-item:nth-child(9) { transform: rotate(270deg); }
.circle-item:nth-child(10) { transform: rotate(300deg); }
.circle-item:nth-child(11) { transform: rotate(330deg); }
.circle-item:nth-child(12) { transform: rotate(360deg); }

.circle-item:nth-child(1)::before { animation-delay: -1.1s; }
.circle-item:nth-child(2)::before { animation-delay: -1s; }
.circle-item:nth-child(3)::before { animation-delay: -0.9s; }
.circle-item:nth-child(4)::before { animation-delay: -0.8s; }
.circle-item:nth-child(5)::before { animation-delay: -0.7s; }
.circle-item:nth-child(6)::before { animation-delay: -0.6s; }
.circle-item:nth-child(7)::before { animation-delay: -0.5s; }
.circle-item:nth-child(8)::before { animation-delay: -0.4s; }
.circle-item:nth-child(9)::before { animation-delay: -0.3s; }
.circle-item:nth-child(10)::before { animation-delay: -0.2s; }
.circle-item:nth-child(11)::before { animation-delay: -0.1s; }

@keyframes circleFade {
  0%, 80%, 100% { opacity: 0; transform: scale(0.6); }
  40% { opacity: 1; transform: scale(1); }
}

/* 弹跳样式 */
.spinner-bounce {
  display: flex;
  gap: 10rpx;
}

.bounce-item {
  width: 20rpx;
  height: 20rpx;
  background: #1890ff;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.bounce-item:nth-child(1) { animation-delay: -0.32s; }
.bounce-item:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
