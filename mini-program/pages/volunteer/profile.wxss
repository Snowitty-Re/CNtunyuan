.profile-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 顶部背景区 */
.header-section {
  position: relative;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.4;
}

.orb-1 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.5);
  top: -80rpx;
  right: -60rpx;
}

.orb-2 {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.3);
  bottom: 40rpx;
  left: -60rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 40rpx 30rpx;
}

.user-avatar-wrapper {
  flex-shrink: 0;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.role-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.user-org {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.user-org .iconfont {
  font-size: 24rpx;
}

.user-points {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-points .iconfont {
  font-size: 24rpx;
  color: #FFD700;
}

/* 统计卡片 */
.stats-card {
  position: relative;
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
}

.stat-item:active {
  opacity: 0.7;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

.stat-label {
  font-size: 24rpx;
  color: #8f959e;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e8e8e8;
}

/* 功能菜单 */
.menu-section {
  margin: 32rpx;
}

.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: #FFF0E6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon-wrapper .iconfont {
  font-size: 32rpx;
  color: #FF8C42;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1f2329;
  font-weight: 500;
}

.menu-badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #c9cdd4;
}

/* 用户ID区域 */
.user-id-section {
  margin: 0 32rpx 32rpx;
}

.user-id-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.user-id-row:active {
  background: #fafafa;
}

.user-id-label {
  font-size: 28rpx;
  color: #8f959e;
  margin-right: 24rpx;
}

.user-id-value {
  flex: 1;
  font-size: 28rpx;
  color: #1f2329;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: #FFF0E6;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #FF8C42;
  font-weight: 500;
}

/* 退出登录 */
.logout-section {
  margin: 0 32rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.logout-btn:active {
  background: #FFF1F0;
}

.logout-btn .iconfont {
  font-size: 32rpx;
  color: #ff4d4f;
}

.logout-btn text {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 500;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}
