<view class="workbench-page">
  <!-- 顶部欢迎区 -->
  <view class="header-section">
    <view class="header-bg">
      <view class="gradient-orb orb-1"></view>
      <view class="gradient-orb orb-2"></view>
    </view>
    <view class="header-content">
      <view class="date-text">{{currentDate}}</view>
      <view class="welcome-title">
        <text>早安，</text>
        <text class="user-name">{{userInfo.nickname || '志愿者'}}</text>
      </view>
      <view class="welcome-subtitle">今天也要加油哦 💪</view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{todayStats.pendingCount}}</text>
        <text class="stat-label">待处理任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{todayStats.processingCount}}</text>
        <text class="stat-label">进行中任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{todayStats.helpedCount}}</text>
        <text class="stat-label">已帮助案件</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions-section">
    <view class="section-title">快捷入口</view>
    <view class="quick-actions-grid">
      <view class="quick-action-item" 
            wx:for="{{quickActions}}" 
            wx:key="key"
            wx:if="{{!item.managerOnly || isManager()}}"
            bindtap="onQuickActionTap" 
            data-key="{{item.key}}"
            style="background: {{item.color}}15;">
        <view class="action-icon" style="background: {{item.color}};">
          <text class="iconfont icon-{{item.icon}}"></text>
        </view>
        <text class="action-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 最近任务 -->
  <view class="recent-tasks-section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-icon">
          <text class="iconfont icon-task"></text>
        </view>
        <text class="section-title">最近任务</text>
      </view>
      <view class="more-link" bindtap="goToMyTasks">
        <text>查看全部</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>

    <!-- 任务列表 -->
    <view class="task-list" wx:if="{{recentTasks.length > 0}}">
      <view class="task-item {{item.status}}" 
            wx:for="{{recentTasks}}" 
            wx:key="id" 
            bindtap="goToTaskDetail" 
            data-id="{{item.id}}">
        <view class="task-priority priority-{{item.priority}}"></view>
        <view class="task-content">
          <view class="task-title">{{item.title}}</view>
          <view class="task-meta">
            <text class="task-type">{{taskTypeMap[item.task_type] || '其他'}}</text>
            <text class="task-status status-{{item.status}}">{{statusMap[item.status]}}</text>
            <text class="task-time">{{item.timeAgo}}</text>
          </view>
        </view>
        <view class="task-action" wx:if="{{item.status === 'assigned'}}" catchtap="startTask" data-id="{{item.id}}">
          <text class="action-btn">开始</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <view class="empty-icon">
        <text class="iconfont icon-empty"></text>
      </view>
      <text class="empty-text">暂无任务</text>
      <text class="empty-desc">去任务列表领取新任务吧</text>
      <view class="empty-action" bindtap="goToTaskList">
        <text>去领取</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
