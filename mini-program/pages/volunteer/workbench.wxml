<view class="workbench-page">
  <!-- 顶部欢迎区 -->
  <view class="welcome-section">
    <view class="welcome-bg">
      <view class="gradient-blob blob-1"></view>
      <view class="gradient-blob blob-2"></view>
    </view>
    <view class="welcome-content">
      <view class="date-text">{{currentDate}}</view>
      <view class="welcome-title">
        <text>早安，</text>
        <text class="user-name">{{userInfo.nickname || '志愿者'}}</text>
      </view>
      <view class="welcome-subtitle">今天也要加油哦 💪</view>
    </view>
  </view>

  <!-- 快捷操作网格 -->
  <view class="quick-actions-section">
    <view class="quick-actions-grid">
      <view class="quick-action-item create-task" bindtap="goToCreateTask">
        <view class="action-bg">
          <view class="action-icon">
            <text class="iconfont icon-task"></text>
          </view>
          <text class="action-label">新建任务</text>
        </view>
      </view>
      <view class="quick-action-item report-case" bindtap="goToCreateCase">
        <view class="action-bg">
          <view class="action-icon">
            <text class="iconfont icon-case"></text>
          </view>
          <text class="action-label">上报案件</text>
        </view>
      </view>
      <view class="quick-action-item record-dialect" bindtap="goToCreateDialect">
        <view class="action-bg">
          <view class="action-icon">
            <text class="iconfont icon-mic"></text>
          </view>
          <text class="action-label">录制方言</text>
        </view>
      </view>
      <view class="quick-action-item nearby-clue" bindtap="goToMap">
        <view class="action-bg">
          <view class="action-icon">
            <text class="iconfont icon-location"></text>
          </view>
          <text class="action-label">附近线索</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 今日待办 -->
  <view class="todo-section" wx:if="{{myTasks.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-icon">
          <text class="iconfont icon-todo"></text>
        </view>
        <text class="section-title">今日待办</text>
        <view class="todo-count">{{myTasks.length}}</view>
      </view>
      <view class="more-link" bindtap="goToMyTasks">
        <text>查看全部</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
    
    <view class="todo-list">
      <view class="todo-item {{item.isOverdue ? 'overdue' : ''}}" wx:for="{{myTasks}}" wx:key="id" bindtap="goToTaskDetail" data-id="{{item.id}}">
        <view class="todo-priority priority-{{item.priority}}"></view>
        <view class="todo-content">
          <view class="todo-title">{{item.title}}</view>
          <view class="todo-meta">
            <view class="todo-type">{{taskTypeMap[item.task_type] || '其他'}}</view>
            <view class="todo-deadline">
              <text class="iconfont icon-time"></text>
              <text>{{item.deadline || '无截止'}}</text>
            </view>
          </view>
        </view>
        <view class="todo-action" catchtap="completeTask" data-id="{{item.id}}">
          <view class="complete-btn">
            <text class="iconfont icon-check"></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-todo-section" wx:else>
    <view class="empty-illustration">
      <view class="empty-icon-wrapper">
        <text class="iconfont icon-relax"></text>
      </view>
      <text class="empty-title">今日暂无待办</text>
      <text class="empty-desc">好好休息一下吧</text>
      <view class="empty-action" bindtap="goToTaskList">
        <text>去领取任务</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
  </view>

  <!-- 最近动态 -->
  <view class="activity-section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-icon bg-green">
          <text class="iconfont icon-activity"></text>
        </view>
        <text class="section-title">最近动态</text>
      </view>
    </view>
    <view class="activity-list">
      <view class="activity-item" wx:for="{{activities}}" wx:key="id">
        <view class="activity-dot"></view>
        <view class="activity-content">
          <text class="activity-text">{{item.content}}</text>
          <text class="activity-time">{{item.time}}</text>
        </view>
      </view>
      <view class="empty-activity" wx:if="{{activities.length === 0}}">
        <text>暂无动态</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
