<view class="workbench-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || 'https://picsum.photos/100/100'}}" />
      <view class="user-meta">
        <view class="nickname">{{userInfo.nickname || '志愿者'}}</view>
        <view class="role">{{roleMap[userInfo.role] || '志愿者'}}</view>
      </view>
    </view>
    <view class="user-stats">
      <view class="user-stat">
        <text class="num">{{stats.completedCount}}</text>
        <text class="label">已完成</text>
      </view>
      <view class="user-stat">
        <text class="num">{{stats.pendingCount}}</text>
        <text class="label">待处理</text>
      </view>
      <view class="user-stat">
        <text class="num">{{stats.processingCount}}</text>
        <text class="label">进行中</text>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section">
    <view class="section-title">快捷操作</view>
    <view class="quick-actions">
      <view class="action-item" bindtap="goToCreateTask">
        <view class="action-icon task">
          <text class="iconfont icon-task"></text>
        </view>
        <text class="action-name">新建任务</text>
      </view>
      <view class="action-item" bindtap="goToCreateCase">
        <view class="action-icon case">
          <text class="iconfont icon-case"></text>
        </view>
        <text class="action-name">上报案件</text>
      </view>
      <view class="action-item" bindtap="goToCreateDialect">
        <view class="action-icon dialect">
          <text class="iconfont icon-mic"></text>
        </view>
        <text class="action-name">录制方言</text>
      </view>
      <view class="action-item" bindtap="goToMap">
        <view class="action-icon map">
          <text class="iconfont icon-map"></text>
        </view>
        <text class="action-name">附近线索</text>
      </view>
    </view>
  </view>

  <!-- 我的待办 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">我的待办</view>
      <view class="section-more" bindtap="goToMyTasks">
        查看全部 <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
    <view class="todo-list">
      <view class="todo-item" wx:for="{{myTasks}}" wx:key="id" bindtap="goToTaskDetail" data-id="{{item.id}}">
        <view class="todo-main">
          <view class="todo-title">{{item.title}}</view>
          <view class="todo-meta">
            <text class="todo-type">{{taskTypeMap[item.task_type] || '其他'}}</text>
            <text class="todo-priority priority-{{item.priority}}">{{priorityMap[item.priority]}}</text>
          </view>
        </view>
        <view class="todo-side">
          <view class="todo-deadline {{item.isOverdue ? 'overdue' : ''}}">{{item.deadline || '无截止'}}</view>
          <button class="todo-btn" size="mini" catchtap="completeTask" data-id="{{item.id}}">完成</button>
        </view>
      </view>
      <view class="empty-todo" wx:if="{{myTasks.length === 0}}">
        <text>暂无待办任务</text>
        <navigator url="/pages/tasks/list" class="link">去领取任务</navigator>
      </view>
    </view>
  </view>

  <!-- 最近动态 -->
  <view class="section">
    <view class="section-title">最近动态</view>
    <view class="activity-list">
      <view class="activity-item" wx:for="{{activities}}" wx:key="id">
        <view class="activity-dot"></view>
        <view class="activity-content">
          <text class="activity-text">{{item.content}}</text>
          <text class="activity-time">{{item.time}}</text>
        </view>
      </view>
      <view class="empty-activity" wx:if="{{activities.length === 0}}">
        暂无动态
      </view>
    </view>
  </view>
</view>
