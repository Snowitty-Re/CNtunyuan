.workbench-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  padding: 40rpx 30rpx;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.user-info .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-meta {
  flex: 1;
}

.user-meta .nickname {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.user-meta .role {
  font-size: 24rpx;
  opacity: 0.9;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.user-stat {
  text-align: center;
}

.user-stat .num {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-stat .label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #1890ff;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.section-more .iconfont {
  font-size: 24rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.task {
  background: #e6f7ff;
}

.action-icon.case {
  background: #fff7e6;
}

.action-icon.dialect {
  background: #f6ffed;
}

.action-icon.map {
  background: #f9f0ff;
}

.action-icon .iconfont {
  font-size: 48rpx;
}

.action-icon.task .iconfont {
  color: #1890ff;
}

.action-icon.case .iconfont {
  color: #faad14;
}

.action-icon.dialect .iconfont {
  color: #52c41a;
}

.action-icon.map .iconfont {
  color: #722ed1;
}

.action-name {
  font-size: 26rpx;
  color: #666;
}

/* 待办列表 */
.todo-list {
  padding-top: 20rpx;
}

.todo-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.todo-meta {
  display: flex;
  gap: 12rpx;
}

.todo-type {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.todo-priority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.todo-priority.priority-urgent {
  background: #fff1f0;
  color: #ff4d4f;
}

.todo-priority.priority-high {
  background: #fff7e6;
  color: #faad14;
}

.todo-priority.priority-normal {
  background: #e6f7ff;
  color: #1890ff;
}

.todo-side {
  text-align: right;
  margin-left: 20rpx;
}

.todo-deadline {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.todo-deadline.overdue {
  color: #ff4d4f;
}

.todo-btn {
  margin: 0;
  background: #52c41a;
  color: #fff;
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
}

.empty-todo {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-todo text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-todo .link {
  font-size: 28rpx;
  color: #1890ff;
}

/* 动态列表 */
.activity-list {
  padding-top: 10rpx;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-dot {
  width: 16rpx;
  height: 16rpx;
  background: #1890ff;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.activity-content {
  flex: 1;
}

.activity-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.activity-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.empty-activity {
  text-align: center;
  padding: 60rpx 40rpx;
  font-size: 28rpx;
  color: #999;
}
