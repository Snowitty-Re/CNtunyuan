.workbench-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 顶部欢迎区 */
.header-section {
  position: relative;
  padding: 80rpx 40rpx 100rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.3;
}

.orb-1 {
  width: 300rpx;
  height: 300rpx;
  background: #fff;
  top: -100rpx;
  right: -80rpx;
}

.orb-2 {
  width: 200rpx;
  height: 200rpx;
  background: #FFE5D9;
  bottom: 20rpx;
  left: -60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.date-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-name {
  font-weight: 600;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
}

/* 今日统计 */
.stats-section {
  margin: -60rpx 32rpx 32rpx;
  position: relative;
  z-index: 2;
}

.stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
}

.stat-label {
  font-size: 24rpx;
  color: #8f959e;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e8e8e8;
}

/* 快捷入口 */
.quick-actions-section {
  margin: 0 32rpx 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 24rpx;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 0;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.quick-action-item:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon .iconfont {
  font-size: 44rpx;
  color: #fff;
}

.action-label {
  font-size: 26rpx;
  color: #1f2329;
  font-weight: 500;
}

/* 最近任务 */
.recent-tasks-section {
  margin: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  width: 48rpx;
  height: 48rpx;
  background: #FFF0E6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title-icon .iconfont {
  font-size: 28rpx;
  color: #FF8C42;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
}

.more-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #8f959e;
}

.more-link .iconfont {
  font-size: 24rpx;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.task-item:active {
  background: #fafafa;
}

.task-priority {
  width: 6rpx;
  height: 60rpx;
  border-radius: 3rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-priority.urgent { background: #ff4d4f; }
.task-priority.high { background: #FF8C42; }
.task-priority.normal { background: #1890ff; }
.task-priority.low { background: #52c41a; }

.task-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.task-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2329;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.task-type {
  font-size: 22rpx;
  color: #FF8C42;
  background: #FFF0E6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.task-status.assigned { 
  color: #1890ff; 
  background: #E6F7FF;
}
.task-status.processing { 
  color: #FAAD14; 
  background: #FFF7E6;
}
.task-status.completed { 
  color: #52c41a; 
  background: #F6FFED;
}
.task-status.pending { 
  color: #8f959e; 
  background: #f5f5f5;
}

.task-time {
  font-size: 22rpx;
  color: #8f959e;
}

.task-action {
  margin-left: 16rpx;
}

.action-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #FF8C42;
  color: #fff;
  font-size: 24rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #f5f7fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon .iconfont {
  font-size: 60rpx;
  color: #c9cdd4;
}

.empty-text {
  font-size: 30rpx;
  color: #1f2329;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8f959e;
  margin-bottom: 32rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: #FF8C42;
  border-radius: 32rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.empty-action .iconfont {
  font-size: 24rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}
