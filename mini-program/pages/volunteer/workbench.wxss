.workbench-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FDF8F3 100%);
}

/* 欢迎区域 */
.welcome-section {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  overflow: hidden;
}

.welcome-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.gradient-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.3;
}

.blob-1 {
  width: 300rpx;
  height: 300rpx;
  background: #fff;
  top: -100rpx;
  right: -80rpx;
}

.blob-2 {
  width: 200rpx;
  height: 200rpx;
  background: #FFE5D9;
  bottom: 20rpx;
  left: -60rpx;
}

.welcome-content {
  position: relative;
  z-index: 1;
}

.date-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-name {
  font-weight: 600;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
}

/* 快捷操作 */
.quick-actions-section {
  margin: -20rpx 32rpx 40rpx;
  position: relative;
  z-index: 2;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.quick-action-item {
  height: 200rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--shadow);
  transition: all 0.3s ease;
}

.quick-action-item:active {
  transform: scale(0.98);
}

.action-bg {
  height: 100%;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.quick-action-item.create-task .action-bg {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
}

.quick-action-item.report-case .action-bg {
  background: linear-gradient(135deg, #3498DB 0%, #5DADE2 100%);
}

.quick-action-item.record-dialect .action-bg {
  background: linear-gradient(135deg, #27AE60 0%, #58D68D 100%);
}

.quick-action-item.nearby-clue .action-bg {
  background: linear-gradient(135deg, #9B59B6 0%, #BB8FCE 100%);
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon .iconfont {
  font-size: 36rpx;
  color: #fff;
}

.action-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* 区块通用样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title-icon.bg-green {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
}

.title-icon .iconfont {
  font-size: 32rpx;
  color: var(--primary);
}

.title-icon.bg-green .iconfont {
  color: #27AE60;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.todo-count {
  min-width: 40rpx;
  height: 40rpx;
  background: #FF4D4F;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}

.more-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.more-link .iconfont {
  font-size: 24rpx;
}

/* 待办列表 */
.todo-section {
  margin: 0 32rpx 40rpx;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  overflow: hidden;
  transition: all 0.3s ease;
}

.todo-item:active {
  transform: scale(0.99);
}

.todo-item.overdue {
  background: #FFF1F0;
}

.todo-priority {
  width: 8rpx;
  height: 80rpx;
  border-radius: 4rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.todo-priority.urgent { background: linear-gradient(180deg, #FF4D4F 0%, #FF7875 100%); }
.todo-priority.high { background: linear-gradient(180deg, #FF8C42 0%, #FFB085 100%); }
.todo-priority.normal { background: linear-gradient(180deg, #3498DB 0%, #5DADE2 100%); }
.todo-priority.low { background: linear-gradient(180deg, #27AE60 0%, #58D68D 100%); }

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.todo-type {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(255, 140, 66, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.todo-deadline {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.todo-deadline .iconfont {
  font-size: 24rpx;
}

.todo-item.overdue .todo-deadline {
  color: #FF4D4F;
}

.todo-action {
  margin-left: 20rpx;
}

.complete-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.complete-btn:active {
  transform: scale(0.9);
}

.complete-btn .iconfont {
  font-size: 36rpx;
  color: #27AE60;
}

/* 空待办 */
.empty-todo-section {
  margin: 0 32rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
}

.empty-illustration {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-icon-wrapper .iconfont {
  font-size: 80rpx;
  color: #27AE60;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-action .iconfont {
  font-size: 24rpx;
}

/* 动态区域 */
.activity-section {
  margin: 0 32rpx 40rpx;
}

.activity-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
}

.activity-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 50%;
  margin-right: 24rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.activity-content {
  flex: 1;
}

.activity-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.activity-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.empty-activity {
  text-align: center;
  padding: 60rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.safe-bottom {
  height: 40rpx;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
