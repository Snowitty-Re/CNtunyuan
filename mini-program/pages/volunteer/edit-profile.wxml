<view class="edit-profile-page">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <image class="avatar" src="{{form.avatar}}" mode="aspectFill" />
      <view class="avatar-mask" wx:if="{{uploadLoading}}">
        <view class="loading-spinner"></view>
      </view>
      <view class="avatar-edit-icon">
        <text class="iconfont icon-camera"></text>
      </view>
    </view>
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <!-- 基本信息表单 -->
  <view class="form-section">
    <view class="section-title">基本信息</view>
    
    <view class="form-item">
      <text class="label required">昵称</text>
      <input 
        class="input"
        placeholder="请输入昵称" 
        value="{{form.nickname}}"
        data-field="nickname"
        bindinput="onInput"
        maxlength="20"
      />
    </view>
    
    <view class="form-item">
      <text class="label required">真实姓名</text>
      <input 
        class="input"
        placeholder="请输入真实姓名" 
        value="{{form.realName}}"
        data-field="realName"
        bindinput="onInput"
        maxlength="20"
      />
    </view>
  </view>

  <!-- 联系方式表单 -->
  <view class="form-section">
    <view class="section-title">联系方式</view>
    
    <view class="form-item">
      <text class="label">手机号</text>
      <view class="input-group">
        <input 
          class="input"
          type="number"
          placeholder="请输入手机号" 
          value="{{form.phone}}"
          data-field="phone"
          bindinput="onInput"
          maxlength="11"
        />
      </view>
    </view>
    
    <!-- 手机号变更验证 -->
    <view class="form-item verify-item" wx:if="{{form.phone && form.phone !== originalForm.phone}}">
      <text class="label">验证码</text>
      <view class="verify-group">
        <input 
          class="verify-input"
          type="number"
          placeholder="请输入验证码" 
          value="{{phoneCode}}"
          data-type="phoneCode"
          bindinput="onCodeInput"
          maxlength="6"
        />
        <button 
          class="verify-btn {{countdown > 0 && codeType === 'phone' ? 'disabled' : ''}}" 
          bindtap="sendCode"
          data-type="phone"
          disabled="{{countdown > 0 && codeType === 'phone'}}">
          {{countdown > 0 && codeType === 'phone' ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>
    
    <view class="form-item">
      <text class="label">邮箱</text>
      <input 
        class="input"
        placeholder="请输入邮箱" 
        value="{{form.email}}"
        data-field="email"
        bindinput="onInput"
        maxlength="100"
      />
    </view>
    
    <!-- 邮箱变更验证 -->
    <view class="form-item verify-item" wx:if="{{form.email && form.email !== originalForm.email}}">
      <text class="label">验证码</text>
      <view class="verify-group">
        <input 
          class="verify-input"
          placeholder="请输入验证码" 
          value="{{emailCode}}"
          data-type="emailCode"
          bindinput="onCodeInput"
          maxlength="6"
        />
        <button 
          class="verify-btn {{countdown > 0 && codeType === 'email' ? 'disabled' : ''}}" 
          bindtap="sendCode"
          data-type="email"
          disabled="{{countdown > 0 && codeType === 'email'}}">
          {{countdown > 0 && codeType === 'email' ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 安全设置 -->
  <view class="form-section">
    <view class="section-title">安全设置</view>
    <view class="form-item arrow-item" bindtap="showPasswordModal">
      <text class="label">修改密码</text>
      <text class="iconfont icon-arrow-right arrow-icon"></text>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="footer">
    <button 
      class="save-btn {{loading ? 'loading' : ''}}" 
      bindtap="saveProfile" 
      disabled="{{loading}}">
      {{loading ? '保存中...' : '保存'}}
    </button>
  </view>

  <!-- 修改密码弹窗 -->
  <view class="modal {{showPasswordModal ? 'show' : ''}}" bindtap="closePasswordModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改密码</text>
        <text class="modal-close iconfont icon-close" bindtap="closePasswordModal"></text>
      </view>
      
      <view class="modal-body">
        <view class="form-item vertical">
          <text class="label">原密码</text>
          <input 
            class="input"
            type="password"
            placeholder="请输入原密码" 
            value="{{passwordForm.oldPassword}}"
            data-field="oldPassword"
            bindinput="onPasswordInput"
            maxlength="32"
          />
        </view>
        
        <view class="form-item vertical">
          <text class="label">新密码</text>
          <input 
            class="input"
            type="password"
            placeholder="请输入新密码（至少6位）" 
            value="{{passwordForm.newPassword}}"
            data-field="newPassword"
            bindinput="onPasswordInput"
            maxlength="32"
          />
        </view>
        
        <view class="form-item vertical">
          <text class="label">确认密码</text>
          <input 
            class="input"
            type="password"
            placeholder="请再次输入新密码" 
            value="{{passwordForm.confirmPassword}}"
            data-field="confirmPassword"
            bindinput="onPasswordInput"
            maxlength="32"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="closePasswordModal">取消</button>
        <button class="confirm-btn {{loading ? 'loading' : ''}}" bindtap="savePassword" disabled="{{loading}}">
          {{loading ? '保存中...' : '确认修改'}}
        </button>
      </view>
    </view>
  </view>
</view>
