.edit-profile-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 160rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #fff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #FF8C42;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 66, 0.3);
}

.avatar-edit-icon .iconfont {
  font-size: 24rpx;
  color: #fff;
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单区块 */
.form-section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.section-title {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.vertical {
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #1f2329;
  flex-shrink: 0;
}

.label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.form-item.vertical .label {
  width: auto;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2329;
  text-align: right;
  height: 48rpx;
  min-height: 48rpx;
}

.input-group {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 验证码区域 */
.verify-item {
  background: #FFF9F5;
}

.verify-group {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.verify-input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2329;
  text-align: right;
  height: 48rpx;
  min-height: 48rpx;
}

.verify-btn {
  padding: 12rpx 20rpx;
  background: #FF8C42;
  color: #fff;
  font-size: 24rpx;
  border-radius: 8rpx;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1.5;
}

.verify-btn.disabled {
  background: #c9cdd4;
}

/* 箭头项 */
.arrow-item {
  cursor: pointer;
}

.arrow-item:active {
  background: #fafafa;
}

.arrow-icon {
  font-size: 28rpx;
  color: #c9cdd4;
}

/* 底部保存按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.save-btn.loading {
  opacity: 0.7;
}

.save-btn[disabled] {
  background: #c9cdd4;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2329;
}

.modal-close {
  font-size: 40rpx;
  color: #8f959e;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

.modal-body .form-item {
  padding: 16rpx 0;
  border-bottom: none;
}

.modal-body .input {
  width: 100%;
  text-align: left;
  background: #f5f7fa;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
  height: auto;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.confirm-btn.loading {
  opacity: 0.7;
}

.confirm-btn[disabled] {
  background: #c9cdd4;
}
