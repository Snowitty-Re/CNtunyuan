<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-main" bindtap="editProfile">
      <image class="avatar" src="{{userInfo.avatar || 'https://picsum.photos/100/100'}}" />
      <view class="user-info">
        <view class="nickname-row">
          <text class="nickname">{{userInfo.nickname || '未设置昵称'}}</text>
          <view class="role-tag">{{roleMap[userInfo.role] || '志愿者'}}</view>
        </view>
        <view class="org-name" wx:if="{{userInfo.org}}">{{userInfo.org.name}}</view>
        <view class="user-id" bindtap="copyId">
          ID: {{userInfo.id}}
          <text class="copy-btn">复制</text>
        </view>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>
    
    <!-- 统计数据 -->
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-num">{{stats.taskCount}}</text>
        <text class="stat-label">任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.caseCount}}</text>
        <text class="stat-label">案件</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.dialectCount}}</text>
        <text class="stat-label">方言</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.score}}</text>
        <text class="stat-label">积分</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="section-title">我的服务</view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{menuList}}" wx:key="text" bindtap="onMenuTap" data-url="{{item.url}}">
        <view class="menu-icon-wrap">
          <text class="iconfont icon-{{item.icon}}"></text>
          <view class="badge" wx:if="{{item.badge > 0}}">{{item.badge > 99 ? '99+' : item.badge}}</view>
        </view>
        <text class="menu-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 通用功能 -->
  <view class="section">
    <view class="section-title">通用</view>
    <view class="menu-list">
      <view class="list-item" bindtap="onFunctionTap" data-type="notification">
        <text class="iconfont icon-notification list-icon"></text>
        <text class="list-text">消息通知</text>
        <text class="iconfont icon-arrow-right list-arrow"></text>
      </view>
      <view class="list-item" bindtap="onFunctionTap" data-type="settings">
        <text class="iconfont icon-settings list-icon"></text>
        <text class="list-text">设置</text>
        <text class="iconfont icon-arrow-right list-arrow"></text>
      </view>
      <view class="list-item" bindtap="onFunctionTap" data-type="help">
        <text class="iconfont icon-help list-icon"></text>
        <text class="list-text">帮助与反馈</text>
        <text class="iconfont icon-arrow-right list-arrow"></text>
      </view>
      <view class="list-item" bindtap="onFunctionTap" data-type="about">
        <text class="iconfont icon-about list-icon"></text>
        <text class="list-text">关于我们</text>
        <text class="iconfont icon-arrow-right list-arrow"></text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
