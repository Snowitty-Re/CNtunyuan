<view class="profile-page">
  <!-- 顶部背景区 -->
  <view class="header-section">
    <view class="header-bg">
      <view class="gradient-orb orb-1"></view>
      <view class="gradient-orb orb-2"></view>
    </view>

    <!-- 用户信息卡 -->
    <view class="user-card">
      <view class="user-avatar-wrapper">
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      </view>
      
      <view class="user-info">
        <view class="user-name-row">
          <text class="user-name">{{userInfo.nickname || '志愿者'}}</text>
          <view class="role-badge" style="background: {{roleColorMap[userInfo.role]}}20; color: {{roleColorMap[userInfo.role]}};">
            {{roleMap[userInfo.role] || '志愿者'}}
          </view>
        </view>
        <view class="user-org" wx:if="{{userInfo.org}}">
          <text class="iconfont icon-org"></text>
          <text>{{userInfo.org.name}}</text>
        </view>
        <view class="user-points">
          <text class="iconfont icon-star"></text>
          <text>积分 {{stats.points}}</text>
        </view>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="onStatTap" data-type="task">
        <text class="stat-value">{{stats.taskCount}}</text>
        <text class="stat-label">我的任务</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onStatTap" data-type="case">
        <text class="stat-value">{{stats.caseCount}}</text>
        <text class="stat-label">我的案件</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onStatTap" data-type="dialect">
        <text class="stat-value">{{stats.dialectCount}}</text>
        <text class="stat-label">方言录音</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onStatTap" data-type="points">
        <text class="stat-value">{{stats.points}}</text>
        <text class="stat-label">我的积分</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-list">
      <view class="menu-item" 
            wx:for="{{menuList}}" 
            wx:key="text" 
            bindtap="onMenuTap" 
            data-index="{{index}}">
        <view class="menu-icon-wrapper">
          <text class="iconfont icon-{{item.icon}}"></text>
        </view>
        <text class="menu-text">{{item.text}}</text>
        <view class="menu-badge" wx:if="{{item.badge > 0}}">{{item.badge > 99 ? '99+' : item.badge}}</view>
        <text class="iconfont icon-arrow-right menu-arrow"></text>
      </view>
    </view>
  </view>

  <!-- 用户信息ID -->
  <view class="user-id-section">
    <view class="user-id-row" bindtap="copyUserId">
      <text class="user-id-label">用户ID</text>
      <text class="user-id-value">{{userInfo.id || '--'}}</text>
      <text class="copy-btn">复制</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">
      <text class="iconfont icon-logout"></text>
      <text>退出登录</text>
    </button>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
