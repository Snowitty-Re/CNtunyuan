<view class="task-detail-page">
  <!-- 加载中 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 内容区 -->
  <block wx:elif="{{task}}">
    <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
      <!-- 任务头部卡片 -->
      <view class="header-card">
        <view class="header-tags">
          <view class="status-badge status-{{task.status}}">
            {{statusMap[task.status] || task.status}}
          </view>
          <view class="priority-badge priority-{{task.priority}}">
            {{priorityMap[task.priority]}}
          </view>
        </view>
        <view class="task-title">{{task.title}}</view>
        <view class="task-meta">
          <text class="meta-item">创建时间：{{task.created_at}}</text>
          <text class="meta-item overdue" wx:if="{{task.isOverdue}}">已逾期</text>
        </view>
      </view>

      <!-- 任务信息 -->
      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">📋</text>
          <text>任务信息</text>
        </view>
        <view class="info-list">
          <view class="info-item">
            <text class="label">任务编号</text>
            <text class="value">{{task.code || task.id}}</text>
          </view>
          <view class="info-item" wx:if="{{task.deadline}}">
            <text class="label">截止时间</text>
            <text class="value {{task.isOverdue ? 'overdue' : ''}}">{{task.deadline}}</text>
          </view>
          <view class="info-item" wx:if="{{task.address}}">
            <text class="label">任务地点</text>
            <view class="value location" bindtap="viewLocation">
              <text class="iconfont icon-location"></text>
              <text class="location-text">{{task.address}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 执行人信息 -->
      <view class="section-card" wx:if="{{task.assignee}}">
        <view class="section-title">
          <text class="title-icon">👤</text>
          <text>执行人</text>
        </view>
        <view class="assignee-card" bindtap="viewAssignee">
          <image class="avatar" src="{{task.assignee.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="info">
            <view class="name">{{task.assignee.nickname || task.assignee.name}}</view>
            <view class="phone" wx:if="{{task.assignee.phone}}">{{task.assignee.phone}}</view>
          </view>
          <text class="iconfont icon-arrow-right"></text>
        </view>
      </view>
      <view class="section-card" wx:elif="{{task.status === 'pending'}}">
        <view class="section-title">
          <text class="title-icon">👤</text>
          <text>执行人</text>
        </view>
        <view class="unassigned-tip">
          <text class="iconfont icon-info"></text>
          <text>暂无执行人，等待分配</text>
        </view>
      </view>

      <!-- 任务描述 -->
      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">📝</text>
          <text>任务描述</text>
        </view>
        <view class="description">{{task.description || '暂无描述'}}</view>
      </view>

      <!-- 进度信息 -->
      <view class="section-card" wx:if="{{task.progress !== undefined && task.progress !== null}}">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text>当前进度</text>
        </view>
        <view class="progress-wrapper">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{task.progress}}%"></view>
          </view>
          <view class="progress-info">
            <text class="progress-text">{{task.progress}}%</text>
            <text class="progress-status" wx:if="{{task.progress === 100}}">已完成</text>
          </view>
        </view>
      </view>

      <!-- 关联案件 -->
      <view class="section-card" wx:if="{{task.missing_person_id}}">
        <view class="section-title">
          <text class="title-icon">🔗</text>
          <text>关联案件</text>
        </view>
        <view class="case-card" bindtap="goToCase">
          <view class="case-info">
            <image class="case-avatar" src="{{task.missing_person?.photo || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="case-detail">
              <view class="case-name">{{task.missing_person?.name || '查看案件详情'}}</view>
              <view class="case-desc" wx:if="{{task.missing_person}}">
                {{task.missing_person.age}}岁 · {{task.missing_person.last_seen_location}}
              </view>
            </view>
          </view>
          <text class="iconfont icon-arrow-right"></text>
        </view>
      </view>

      <!-- 任务日志 -->
      <view class="section-card">
        <view class="section-title">
          <text class="title-icon">📜</text>
          <text>操作记录</text>
        </view>
        <view class="logs-list">
          <view class="log-item" wx:for="{{logs}}" wx:key="id">
            <view class="log-dot"></view>
            <view class="log-content">
              <view class="log-header">
                <text class="log-action">{{item.action}}</text>
                <text class="log-time">{{item.created_at}}</text>
              </view>
              <view class="log-desc" wx:if="{{item.description}}">{{item.description}}</view>
              <view class="log-user" wx:if="{{item.operator}}">
                操作人：{{item.operator.nickname || item.operator.name}}
              </view>
            </view>
          </view>
          <view class="empty-logs" wx:if="{{logs.length === 0}}">
            <text>暂无操作记录</text>
          </view>
        </view>
      </view>

      <!-- 底部留白 -->
      <view class="safe-bottom" style="height: 160rpx;"></view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="action-bar" wx:if="{{task.status !== 'completed' && task.status !== 'cancelled'}}">
      <!-- 管理者操作 -->
      <block wx:if="{{isManager}}">
        <!-- 待分配状态：分配任务、取消任务 -->
        <block wx:if="{{task.status === 'pending'}}">
          <view class="action-group">
            <button class="action-btn secondary" bindtap="cancelTask" loading="{{actionLoading}}">
              取消任务
            </button>
            <button class="action-btn primary" bindtap="assignTask" loading="{{actionLoading}}">
              分配任务
            </button>
          </view>
        </block>
        <!-- 进行中状态：可取消 -->
        <block wx:elif="{{task.status === 'processing'}}">
          <button class="action-btn warning" bindtap="cancelTask" loading="{{actionLoading}}">
            取消任务
          </button>
        </block>
      </block>

      <!-- 执行人操作 -->
      <block wx:if="{{isAssignee}}">
        <!-- 待分配/已分配状态：开始任务 -->
        <block wx:if="{{task.status === 'pending'}}">
          <button class="action-btn primary" bindtap="startTask" loading="{{actionLoading}}">
            开始任务
          </button>
        </block>
        <!-- 进行中状态：更新进度、完成任务 -->
        <block wx:elif="{{task.status === 'processing'}}">
          <view class="action-group">
            <button class="action-btn secondary" bindtap="showProgressModal" loading="{{actionLoading}}">
              更新进度
            </button>
            <button class="action-btn success" bindtap="completeTask" loading="{{actionLoading}}">
              完成任务
            </button>
          </view>
        </block>
      </block>

      <!-- 非执行人提示 -->
      <block wx:if="{{!isAssignee && !isManager && task.status === 'pending'}}">
        <button class="action-btn disabled" disabled>
          等待分配
        </button>
      </block>
    </view>
  </block>

  <!-- 进度更新弹窗 -->
  <view class="modal" wx:if="{{showProgressModal}}" bindtap="hideProgressModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">更新进度</text>
        <text class="modal-close" bindtap="hideProgressModal">×</text>
      </view>
      <view class="modal-body">
        <view class="progress-value">{{progressInput}}%</view>
        <slider 
          value="{{progressInput}}" 
          min="0" 
          max="100" 
          step="5"
          activeColor="#FF8C42"
          block-size="24"
          bindchange="onProgressChange"
        />
        <view class="progress-hint">拖动滑块调整任务进度</view>
      </view>
      <view class="modal-footer">
        <button class="btn secondary" bindtap="hideProgressModal">取消</button>
        <button class="btn primary" bindtap="submitProgress" loading="{{actionLoading}}">确定</button>
      </view>
    </view>
  </view>
</view>
