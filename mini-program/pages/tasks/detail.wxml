<view class="task-detail-page">
  <view class="loading" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <view class="content" wx:elif="{{task}}">
    <!-- 任务头部 -->
    <view class="task-header">
      <view class="status-badge status-{{task.status}}">{{statusMap[task.status]}}</view>
      <view class="priority-badge priority-{{task.priority}}">{{priorityMap[task.priority]}}</view>
    </view>

    <view class="task-title">{{task.title}}</view>

    <!-- 基本信息 -->
    <view class="info-section">
      <view class="section-title">任务信息</view>
      <view class="info-item">
        <text class="label">任务编号</text>
        <text class="value">{{task.code || task.id}}</text>
      </view>
      <view class="info-item">
        <text class="label">任务类型</text>
        <text class="value">{{taskTypeMap[task.task_type] || '其他'}}</text>
      </view>
      <view class="info-item">
        <text class="label">创建时间</text>
        <text class="value">{{task.created_at}}</text>
      </view>
      <view class="info-item" wx:if="{{task.deadline}}">
        <text class="label">截止时间</text>
        <text class="value {{task.isOverdue ? 'overdue' : ''}}">{{task.deadline}}</text>
      </view>
    </view>

    <!-- 执行人员 -->
    <view class="info-section" wx:if="{{task.assignee}}">
      <view class="section-title">执行人</view>
      <view class="assignee-card" bindtap="viewAssignee">
        <image class="avatar" src="{{task.assignee.avatar || 'https://picsum.photos/100/100'}}" />
        <view class="info">
          <view class="name">{{task.assignee.nickname}}</view>
          <view class="phone" wx:if="{{task.assignee.phone}}">{{task.assignee.phone}}</view>
        </view>
      </view>
    </view>

    <!-- 任务描述 -->
    <view class="info-section">
      <view class="section-title">任务描述</view>
      <view class="description">{{task.description || '暂无描述'}}</view>
    </view>

    <!-- 位置信息 -->
    <view class="info-section" wx:if="{{task.latitude && task.longitude}}">
      <view class="section-title">位置信息</view>
      <view class="location-card" bindtap="viewLocation">
        <text class="iconfont icon-location"></text>
        <view class="address">{{task.address || '点击查看位置'}}</view>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>

    <!-- 关联案件 -->
    <view class="info-section" wx:if="{{task.missing_person_id}}">
      <view class="section-title">关联案件</view>
      <view class="case-card" bindtap="goToCase">
        <view class="case-name">{{task.missing_person ? task.missing_person.name : '查看案件详情'}}</view>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>

    <!-- 进度信息 -->
    <view class="info-section" wx:if="{{task.progress !== undefined}}">
      <view class="section-title">当前进度</view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{task.progress}}%"></view>
      </view>
      <view class="progress-text">{{task.progress}}%</view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{task && task.status !== 'completed' && task.status !== 'cancelled'}}">
    <block wx:if="{{task.status === 'pending'}}">
      <button class="action-btn primary" bindtap="claimTask" loading="{{actionLoading}}">
        领取任务
      </button>
    </block>
    <block wx:elif="{{task.status === 'assigned'}}">
      <button class="action-btn primary" bindtap="startTask" loading="{{actionLoading}}">
        开始执行
      </button>
    </block>
    <block wx:elif="{{task.status === 'processing'}}">
      <view class="action-group">
        <button class="action-btn secondary" bindtap="showProgressModal">更新进度</button>
        <button class="action-btn success" bindtap="completeTask">标记完成</button>
      </view>
    </block>
  </view>

  <!-- 进度更新弹窗 -->
  <view class="modal" wx:if="{{showProgressModal}}" bindtap="hideProgressModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">更新进度</text>
        <text class="modal-close" bindtap="hideProgressModal">×</text>
      </view>
      <view class="modal-body">
        <view class="progress-value">{{progressInput}}%</view>
        <slider 
          value="{{progressInput}}" 
          min="0" 
          max="100" 
          step="5"
          activeColor="#1890ff"
          block-size="24"
          bindchange="onProgressChange"
        />
      </view>
      <view class="modal-footer">
        <button class="btn secondary" bindtap="hideProgressModal">取消</button>
        <button class="btn primary" bindtap="submitProgress" loading="{{actionLoading}}">确定</button>
      </view>
    </view>
  </view>
</view>
