<view class="container">
  <view class="task-info" wx:if="{{task}}">
    <text class="task-title">{{task.title}}</text>
    <text class="task-desc">{{task.description}}</text>
  </view>

  <view class="form-section">
    <view class="form-group">
      <view class="form-label required">反馈内容</view>
      <textarea 
        class="form-textarea"
        placeholder="请详细描述任务执行情况、遇到的问题和解决方案..."
        maxlength="500"
        value="{{feedback}}"
        bindinput="onFeedbackInput"
      />
      <view class="word-count">{{feedback.length}}/500</view>
    </view>

    <view class="form-group">
      <view class="form-label">任务结果</view>
      <textarea 
        class="form-textarea"
        placeholder="请简要说明任务最终结果..."
        maxlength="200"
        value="{{result}}"
        bindinput="onResultInput"
      />
    </view>

    <view class="form-group">
      <view class="form-label">上传图片</view>
      <view class="image-list">
        <view 
          class="image-item"
          wx:for="{{photos}}"
          wx:key="index"
        >
          <image 
            src="{{item}}" 
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewImage"
          />
          <text 
            class="delete-icon"
            data-index="{{index}}"
            catchtap="deleteImage"
          >×</text>
        </view>
        
        <view class="upload-btn" bindtap="chooseImage" wx:if="{{photos.length < 9}}">
          <text class="upload-icon">+</text>
          <text class="upload-text">{{photos.length}}/9</text>
        </view>
      </view>
    </view>
  </view>

  <view class="submit-section">
    <button 
      class="submit-btn"
      type="primary"
      bindtap="submitFeedback"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      提交反馈
    </button>
  </view>
</view>
