<view class="create-task-page">
  <!-- 加载中 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 表单 -->
  <scroll-view class="form-container" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
    <view class="form-section">
      <view class="section-title">基本信息</view>
      
      <!-- 任务标题 -->
      <view class="form-item">
        <view class="label required">任务标题</view>
        <input 
          class="input"
          placeholder="请输入任务标题"
          value="{{form.title}}"
          data-field="title"
          bindinput="onInput"
          maxlength="100"
        />
      </view>
      
      <!-- 任务描述 -->
      <view class="form-item">
        <view class="label required">任务描述</view>
        <textarea 
          class="textarea"
          placeholder="请详细描述任务内容、要求等信息"
          value="{{form.description}}"
          data-field="description"
          bindinput="onInput"
          maxlength="500"
          auto-height
        />
        <view class="textarea-counter">{{form.description.length || 0}}/500</view>
      </view>
      
      <!-- 优先级 -->
      <view class="form-item">
        <view class="label required">优先级</view>
        <picker bindchange="onPriorityChange" range="{{priorities}}" range-key="label" value="{{priorityIndex}}">
          <view class="picker-value">
            <view class="priority-display priority-{{form.priority}}">
              {{priorities[priorityIndex].label}}
            </view>
            <text class="iconfont icon-arrow-right"></text>
          </view>
        </picker>
      </view>
      
      <!-- 截止日期 -->
      <view class="form-item">
        <view class="label required">截止日期</view>
        <picker mode="date" bindchange="onDateChange" value="{{form.deadline}}" start="{{minDate}}">
          <view class="picker-value {{form.deadline ? '' : 'placeholder'}}">
            <text>{{form.deadline || '请选择截止日期'}}</text>
            <text class="iconfont icon-arrow-right"></text>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">关联信息</view>
      
      <!-- 关联案件 -->
      <view class="form-item">
        <view class="label">关联案件</view>
        <picker bindchange="onCaseChange" range="{{cases}}" range-key="name" value="{{caseIndex}}">
          <view class="picker-value {{form.missing_person_id ? '' : 'placeholder'}}">
            <block wx:if="{{form.missing_person_id}}">
              <view class="case-display">
                <text class="case-name">{{cases[caseIndex].name}}</text>
                <text class="case-info" wx:if="{{cases[caseIndex].age}}">{{cases[caseIndex].age}}岁</text>
              </view>
            </block>
            <block wx:else>
              <text>请选择关联案件（可选）</text>
            </block>
            <text class="iconfont icon-arrow-right"></text>
          </view>
        </picker>
      </view>
      
      <!-- 分配执行人 -->
      <view class="form-item">
        <view class="label">分配执行人</view>
        <picker bindchange="onUserChange" range="{{users}}" range-key="nickname" value="{{userIndex}}">
          <view class="picker-value {{form.assignee_id ? '' : 'placeholder'}}">
            <block wx:if="{{form.assignee_id}}">
              <view class="user-display">
                <image class="user-avatar" src="{{users[userIndex].avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
                <text class="user-name">{{users[userIndex].nickname || users[userIndex].name}}</text>
              </view>
            </block>
            <block wx:else>
              <text>请选择执行人（可选）</text>
            </block>
            <text class="iconfont icon-arrow-right"></text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-section">
      <view class="tip-item">
        <text class="iconfont icon-info"></text>
        <text class="tip-text">创建任务后，被分配的执行人将收到通知</text>
      </view>
      <view class="tip-item">
        <text class="iconfont icon-info"></text>
        <text class="tip-text">未分配执行人的任务将显示在任务中心等待领取</text>
      </view>
    </view>

    <!-- 底部留白 -->
    <view class="safe-bottom" style="height: 180rpx;"></view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="footer" wx:if="{{!loading}}">
    <button 
      class="submit-btn {{submitting ? 'loading' : ''}}" 
      bindtap="submit" 
      disabled="{{submitting}}"
    >
      <block wx:if="{{submitting}}">
        <view class="btn-spinner"></view>
        <text>创建中...</text>
      </block>
      <block wx:else>
        创建任务
      </block>
    </button>
  </view>
</view>
