<view class="create-task-page">
  <view class="form-section">
    <view class="form-item">
      <view class="label required">任务标题</view>
      <input 
        placeholder="请输入任务标题" 
        value="{{form.title}}"
        data-field="title"
        bindinput="onInput"
      />
    </view>
    
    <view class="form-item">
      <view class="label">任务描述</view>
      <textarea 
        placeholder="请输入任务描述"
        value="{{form.description}}"
        data-field="description"
        bindinput="onInput"
      />
    </view>
    
    <view class="form-item">
      <view class="label">任务类型</view>
      <picker bindchange="onTypeChange" range="{{taskTypes}}" range-key="label" value="{{typeIndex}}">
        <view class="picker-value">
          {{typeName}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="label">优先级</view>
      <picker bindchange="onPriorityChange" range="{{priorities}}" range-key="label" value="{{priorityIndex}}">
        <view class="picker-value">
          {{priorityName}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="label">截止时间</view>
      <picker mode="date" bindchange="onDateChange" value="{{form.deadline}}">
        <view class="picker-value {{form.deadline ? '' : 'placeholder'}}">
          {{form.deadline || '选择日期'}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="label">关联案件</view>
      <picker bindchange="onCaseChange" range="{{cases}}" range-key="name" value="{{caseIndex}}">
        <view class="picker-value {{form.missing_person_id ? '' : 'placeholder'}}">
          {{caseName || '选择案件'}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="label">任务地点</view>
      <view class="location-picker" bindtap="chooseLocation">
        <text class="iconfont icon-location"></text>
        <text class="location-text {{form.address ? '' : 'placeholder'}}">
          {{form.address || '选择位置'}}
        </text>
      </view>
    </view>
  </view>
  
  <view class="footer">
    <button class="submit-btn" type="primary" bindtap="submit" loading="{{loading}}">
      创建任务
    </button>
  </view>
</view>
