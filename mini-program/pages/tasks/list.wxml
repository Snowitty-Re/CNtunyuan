<view class="tasks-page">
  <!-- 统计卡片 -->
  <view class="stats-bar">
    <view class="stat-item {{currentStatus === '' ? 'active' : ''}}" bindtap="filterByStatus" data-status="">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">全部</text>
    </view>
    <view class="stat-item {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="filterByStatus" data-status="pending">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">待分配</text>
    </view>
    <view class="stat-item {{currentStatus === 'assigned' ? 'active' : ''}}" bindtap="filterByStatus" data-status="assigned">
      <text class="stat-num">{{stats.assigned}}</text>
      <text class="stat-label">已分配</text>
    </view>
    <view class="stat-item {{currentStatus === 'processing' ? 'active' : ''}}" bindtap="filterByStatus" data-status="processing">
      <text class="stat-num">{{stats.processing}}</text>
      <text class="stat-label">进行中</text>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item {{currentStatus === '' ? 'active' : ''}}" bindtap="filterByStatus" data-status="">
      全部
    </view>
    <view class="filter-item {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="filterByStatus" data-status="pending">
      待领取
    </view>
    <view class="filter-item {{currentStatus === 'assigned' ? 'active' : ''}}" bindtap="filterByStatus" data-status="assigned">
      已分配
    </view>
    <view class="filter-item {{currentStatus === 'processing' ? 'active' : ''}}" bindtap="filterByStatus" data-status="processing">
      进行中
    </view>
    <view class="filter-item {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="filterByStatus" data-status="completed">
      已完成
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view 
    class="task-list" 
    scroll-y 
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >
    <view class="task-card" wx:for="{{tasks}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="task-header">
        <view class="task-title">{{item.title}}</view>
        <view class="task-status status-{{item.status}}">{{statusMap[item.status]}}</view>
      </view>
      
      <view class="task-info">
        <text class="task-type">{{taskTypeMap[item.task_type] || '其他'}}</text>
        <text class="priority-tag priority-{{item.priority}}">{{priorityMap[item.priority]}}</text>
      </view>
      
      <view class="task-desc" wx:if="{{item.description}}">{{item.description}}</view>
      
      <view class="task-footer">
        <view class="task-location" wx:if="{{item.address}}">
          <text class="iconfont icon-location"></text>
          <text>{{item.address}}</text>
        </view>
        <view class="task-deadline {{item.isOverdue ? 'overdue' : ''}}" wx:if="{{item.deadline}}">
          <text class="iconfont icon-time"></text>
          <text>截止: {{item.deadline}}</text>
        </view>
      </view>
      
      <view class="task-assignee" wx:if="{{item.assignee}}">
        <image class="avatar" src="{{item.assignee.avatar || 'https://picsum.photos/100/100'}}" />
        <text>{{item.assignee.nickname}}</text>
      </view>
      
      <!-- 快速操作 -->
      <view class="quick-actions" wx:if="{{item.status === 'pending'}}" catchtap="stopPropagation">
        <button class="quick-btn" size="mini" type="primary" bindtap="quickClaim" data-id="{{item.id}}">
          领取任务
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && tasks.length === 0}}">
      <image src="https://picsum.photos/200/200?random=empty" mode="aspectFit" />
      <text>暂无任务</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && tasks.length > 0}}">
      没有更多了
    </view>
  </scroll-view>

  <!-- 悬浮按钮 -->
  <view class="fab" bindtap="goToCreate" wx:if="{{canCreate}}">
    <text class="iconfont icon-add"></text>
  </view>
</view>
