.task-detail-page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 加载中 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-wrapper .spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #FF8C42;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-wrapper text {
  font-size: 28rpx;
  color: #999;
}

/* 内容区 */
.content {
  height: 100vh;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  padding: 32rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  color: #fff;
}

.header-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.status-badge,
.priority-badge {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
}

.task-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.task-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.task-meta .overdue {
  color: #FFEB3B;
  font-weight: 500;
}

/* 卡片区块 */
.section-card {
  background: #fff;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 36rpx;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item .label {
  font-size: 28rpx;
  color: #999;
}

.info-item .value {
  font-size: 28rpx;
  color: #333;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-item .value.overdue {
  color: #FF4D4F;
  font-weight: 500;
}

.info-item .location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #FF8C42;
}

.location .iconfont {
  font-size: 28rpx;
}

.location-text {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 执行人卡片 */
.assignee-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.assignee-card .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.assignee-card .info {
  flex: 1;
}

.assignee-card .name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.assignee-card .phone {
  font-size: 26rpx;
  color: #666;
}

.assignee-card .iconfont {
  font-size: 32rpx;
  color: #999;
}

.unassigned-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  color: #999;
  font-size: 28rpx;
  justify-content: center;
}

.unassigned-tip .iconfont {
  font-size: 32rpx;
  color: #FF8C42;
}

/* 任务描述 */
.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

/* 进度条 */
.progress-wrapper {
  padding: 16rpx 0;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8C42, #FFB085);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF8C42;
}

.progress-status {
  font-size: 26rpx;
  color: #52C41A;
  font-weight: 500;
}

/* 案件卡片 */
.case-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #FFF7E6;
  border-radius: 12rpx;
}

.case-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.case-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.case-detail {
  flex: 1;
}

.case-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.case-desc {
  font-size: 24rpx;
  color: #666;
}

.case-card .iconfont {
  font-size: 32rpx;
  color: #999;
}

/* 日志列表 */
.logs-list {
  position: relative;
  padding-left: 24rpx;
}

.logs-list::before {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.log-item {
  position: relative;
  padding: 20rpx 0 20rpx 32rpx;
}

.log-dot {
  position: absolute;
  left: -18rpx;
  top: 28rpx;
  width: 16rpx;
  height: 16rpx;
  background: #FF8C42;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #FF8C42;
}

.log-content {
  background: #f5f7fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-action {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.log-time {
  font-size: 24rpx;
  color: #999;
}

.log-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.log-user {
  font-size: 24rpx;
  color: #999;
}

.empty-logs {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-group {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin: 0;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.success {
  background: #52C41A;
  color: #fff;
}

.action-btn.warning {
  background: #FF4D4F;
  color: #fff;
}

.action-btn.disabled {
  background: #e8e8e8;
  color: #999;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  padding: 0 10rpx;
}

.modal-body {
  padding: 40rpx;
}

.progress-value {
  text-align: center;
  font-size: 60rpx;
  font-weight: 700;
  color: #FF8C42;
  margin-bottom: 20rpx;
}

.progress-hint {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin: 0;
  border: none;
}

.modal-footer .btn::after {
  border: none;
}

.modal-footer .btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.modal-footer .btn.primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  color: #fff;
}
