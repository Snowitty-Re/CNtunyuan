.create-task-page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 加载中 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-wrapper .spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #FF8C42;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-wrapper text {
  font-size: 28rpx;
  color: #999;
}

/* 表单容器 */
.form-container {
  height: 100vh;
  padding-bottom: 140rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  margin: 20rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 0 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 表单项 */
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.label.required::before {
  content: '*';
  color: #FF4D4F;
  margin-right: 8rpx;
}

/* 输入框 */
.input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input::placeholder {
  color: #999;
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.textarea::placeholder {
  color: #999;
}

.textarea-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-value .iconfont {
  font-size: 28rpx;
  color: #999;
}

/* 优先级显示 */
.priority-display {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.priority-urgent {
  background: #FFF1F0;
  color: #FF4D4F;
}

.priority-high {
  background: #FFF7E6;
  color: #FAAD14;
}

.priority-normal {
  background: #E6F7FF;
  color: #1890FF;
}

.priority-low {
  background: #F6FFED;
  color: #52C41A;
}

/* 案件显示 */
.case-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.case-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.case-info {
  font-size: 24rpx;
  color: #999;
}

/* 用户显示 */
.user-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.user-name {
  font-size: 28rpx;
  color: #333;
}

/* 提示信息 */
.tips-section {
  margin: 20rpx;
  padding: 20rpx 24rpx;
  background: #FFF7E6;
  border-radius: 12rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
}

.tip-item .iconfont {
  font-size: 28rpx;
  color: #FF8C42;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.loading {
  opacity: 0.8;
}

.btn-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
