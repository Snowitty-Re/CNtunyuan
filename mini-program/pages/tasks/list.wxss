.tasks-page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 统计横幅 */
.stats-banner {
  position: relative;
  margin: 20rpx;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.25);
}

.stats-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
}

.stat-item:active {
  background: rgba(255, 255, 255, 0.1);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-value.highlight {
  transform: scale(1.1);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 筛选栏 */
.filter-bar {
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.filter-chip.active {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.3);
}

.chip-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.chip-dot.pending { background: #F39C12; }
.chip-dot.processing { background: #27AE60; }
.chip-dot.completed { background: #95A5A6; }
.chip-dot.cancelled { background: #E74C3C; }

.chip-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.filter-chip.active .chip-text {
  color: #fff;
}

/* 任务列表 */
.task-list {
  height: calc(100vh - 280rpx);
  padding: 0 20rpx;
}

.task-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 120rpx;
}

.task-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-accent {
  width: 8rpx;
  flex-shrink: 0;
}

.card-accent.urgent { background: linear-gradient(180deg, #FF4D4F 0%, #FF7875 100%); }
.card-accent.high { background: linear-gradient(180deg, #FF8C42 0%, #FFB085 100%); }
.card-accent.normal { background: linear-gradient(180deg, #3498DB 0%, #5DADE2 100%); }
.card-accent.low { background: linear-gradient(180deg, #27AE60 0%, #58D68D 100%); }

.card-content {
  flex: 1;
  padding: 24rpx;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-pending .status-dot { background: #F39C12; }
.status-processing .status-dot { background: #27AE60; }
.status-completed .status-dot { background: #95A5A6; }
.status-cancelled .status-dot { background: #E74C3C; }

.status-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.priority-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.priority-urgent { background: #FFF1F0; color: #FF4D4F; }
.priority-high { background: #FFF7E6; color: #FAAD14; }
.priority-normal { background: #E6F7FF; color: #1890FF; }
.priority-low { background: #F6FFED; color: #52C41A; }

.task-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-case {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #FFF7E6;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.task-case .iconfont {
  font-size: 24rpx;
  color: #FF8C42;
}

.case-text {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-item .iconfont {
  font-size: 24rpx;
}

.meta-item.overdue {
  color: #FF4D4F;
}

.meta-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

/* 快速操作 */
.quick-action {
  display: flex;
  align-items: center;
  padding-right: 24rpx;
}

.action-btn-primary {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.3);
}

.action-btn-primary .iconfont {
  font-size: 32rpx;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon-circle {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon-circle .iconfont {
  font-size: 80rpx;
  color: #FF8C42;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF8C42;
  border-radius: 50%;
  animation: dotBounce 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
  max-width: 200rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.fab-bg {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 140, 66, 0.35);
}

.fab-bg .iconfont {
  font-size: 48rpx;
  color: #fff;
}
