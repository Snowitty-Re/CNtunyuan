<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 内容区域 -->
  <block wx:if="{{!loading && dialect}}">
    <!-- 音频播放器 -->
    <view class="player-section">
      <view class="player-card">
        <view class="play-btn {{isPlaying ? 'playing' : ''}}" bindtap="togglePlay">
          <view wx:if="{{!isPlaying}}" class="icon-play"></view>
          <view wx:else class="icon-pause">
            <view class="pause-bar"></view>
            <view class="pause-bar"></view>
          </view>
        </view>
        
        <view class="player-info">
          <text class="audio-title">{{dialect.title || '方言录音'}}</text>
          <view class="progress-section">
            <slider 
              class="progress-slider" 
              value="{{progress}}" 
              block-size="16"
              activeColor="#e67e22"
              backgroundColor="#e0e0e0"
              bindchange="onSliderChange"
              bindchanging="onSliderChanging"
            />
            <view class="time-display">
              <text class="current-time">{{formatTime(currentTime)}}</text>
              <text class="duration">{{formatTime(duration)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 方言信息 -->
    <view class="info-section">
      <view class="info-header">
        <view class="region-tag" wx:if="{{dialect.region || dialect.province}}">
          <text class="region-icon">📍</text>
          <text class="region-text">{{dialect.region || dialect.province}}</text>
        </view>
        <view class="featured-badge" wx:if="{{dialect.is_featured}}">精选</view>
      </view>
      
      <view class="info-desc" wx:if="{{dialect.description}}">
        <text class="desc-text">{{dialect.description}}</text>
      </view>
      
      <view class="info-tags" wx:if="{{dialect.tags && dialect.tags.length > 0}}">
        <text class="info-tag" wx:for="{{dialect.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
      </view>

      <view class="info-stats">
        <view class="stat-item">
          <text class="stat-value">{{formatPlayCount(dialect.play_count)}}</text>
          <text class="stat-label">播放</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{formatPlayCount(dialect.like_count)}}</text>
          <text class="stat-label">点赞</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{formatPlayCount(comments.length)}}</text>
          <text class="stat-label">评论</text>
        </view>
      </view>
    </view>

    <!-- 采集者信息 -->
    <view class="collector-section" bindtap="goToCollectorProfile">
      <view class="section-title">采集者</view>
      <view class="collector-card">
        <image class="collector-avatar" src="{{(dialect.collector && dialect.collector.avatar) || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="collector-info">
          <text class="collector-name">{{(dialect.collector && dialect.collector.nickname) || '志愿者'}}</text>
          <text class="collector-time">{{dialect.formatted_date}}</text>
        </view>
        <view class="collector-arrow">›</view>
      </view>
    </view>

    <!-- 关联走失人员 -->
    <view class="missing-person-section" wx:if="{{missingPerson}}" bindtap="goToMissingPerson">
      <view class="section-title">
        <text>关联走失人员</text>
        <text class="section-more">查看详情 ›</text>
      </view>
      <view class="missing-person-card">
        <image class="mp-avatar" src="{{missingPerson.avatar || missingPerson.photo || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="mp-info">
          <view class="mp-header">
            <text class="mp-name">{{missingPerson.name || '未知'}}</text>
            <view class="mp-status status-{{missingPerson.status}}">{{missingPerson.status_text || '寻找中'}}</view>
          </view>
          <view class="mp-details">
            <text class="mp-detail">{{missingPerson.gender === 'male' ? '男' : missingPerson.gender === 'female' ? '女' : '未知'}}</text>
            <text class="mp-detail" wx:if="{{missingPerson.age}}">{{missingPerson.age}}岁</text>
            <text class="mp-detail" wx:if="{{missingPerson.missing_region}}">{{missingPerson.missing_region}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 评论区域 -->
    <view class="comments-section">
      <view class="section-title">评论 ({{dialect.comment_count || comments.length}})</view>
      
      <!-- 评论列表 -->
      <view class="comments-list" wx:if="{{comments.length > 0}}">
        <view class="comment-item" wx:for="{{comments}}" wx:key="id">
          <image class="comment-avatar" src="{{(item.user && item.user.avatar) || '/images/default-avatar.png'}}" mode="aspectFill"/>
          <view class="comment-content">
            <view class="comment-header">
              <text class="comment-name">{{(item.user && item.user.nickname) || '用户'}}</text>
              <text class="comment-time">{{item.time_text}}</text>
            </view>
            <text class="comment-text">{{item.content}}</text>
          </view>
        </view>
      </view>
      
      <!-- 空评论状态 -->
      <view class="empty-comments" wx:if="{{comments.length === 0}}">
        <text class="empty-text">暂无评论，来说两句吧~</text>
      </view>
      
      <!-- 加载更多 -->
      <view class="comment-more" wx:if="{{comments.length > 0}}">
        <text wx:if="{{commentLoading}}">加载中...</text>
        <text wx:elif="{{commentNoMore}}">没有更多评论了</text>
      </view>
    </view>
  </block>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{!loading && dialect}}">
    <view class="comment-input-wrapper">
      <input 
        class="comment-input" 
        placeholder="写评论..." 
        value="{{commentContent}}"
        bindinput="onCommentInput"
        confirm-type="send"
        bindconfirm="submitComment"
      />
    </view>
    <view class="action-btns">
      <view class="action-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike">
        <text class="action-icon">{{isLiked ? '❤' : '♡'}}</text>
        <text class="action-text">{{dialect.like_count > 0 ? dialect.like_count : '点赞'}}</text>
      </view>
      <button class="action-btn share-btn" open-type="share">
        <text class="action-icon">⤴</text>
        <text class="action-text">分享</text>
      </button>
    </view>
  </view>
</view>
