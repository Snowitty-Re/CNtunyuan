<view class="container">
  <!-- 顶部筛选栏 -->
  <view class="filter-bar">
    <view class="region-picker">
      <picker mode="selector" range="{{regionOptions}}" range-key="name" value="{{selectedRegionIndex}}" bindchange="onRegionChange">
        <view class="picker-content">
          <text class="picker-text">{{regionOptions[selectedRegionIndex].name}}</text>
          <view class="picker-arrow"></view>
        </view>
      </picker>
    </view>
    <view class="filter-info">
      <text class="filter-count">共 {{dialects.length}} 条</text>
    </view>
  </view>

  <!-- 方言列表 -->
  <view class="dialect-list">
    <block wx:for="{{dialects}}" wx:key="id">
      <view class="dialect-card" bindtap="goToDetail" data-id="{{item.id}}">
        <!-- 播放按钮区域 -->
        <view class="play-section">
          <view class="play-btn {{playingId === item.id ? 'playing' : ''}}" 
                catchtap="togglePlay" 
                data-id="{{item.id}}" 
                data-url="{{item.audio_url}}">
            <view class="play-icon">
              <view wx:if="{{playingId !== item.id}}" class="icon-play"></view>
              <view wx:else class="icon-pause">
                <view class="pause-bar"></view>
                <view class="pause-bar"></view>
              </view>
            </view>
          </view>
          <view class="duration">{{formatTime(item.duration)}}</view>
        </view>

        <!-- 内容区域 -->
        <view class="content-section">
          <view class="dialect-header">
            <text class="dialect-title">{{item.title || '方言录音'}}</text>
            <view class="featured-tag" wx:if="{{item.is_featured}}">精选</view>
          </view>
          
          <view class="dialect-desc" wx:if="{{item.description}}">{{item.description}}</view>
          
          <view class="dialect-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
          </view>
          
          <view class="dialect-meta">
            <view class="meta-item region">
              <text class="meta-icon">📍</text>
              <text class="meta-text">{{item.region || item.province || '未知地区'}}</text>
            </view>
            <view class="meta-stats">
              <view class="stat-item">
                <text class="stat-icon">▶</text>
                <text class="stat-num">{{formatPlayCount(item.play_count)}}</text>
              </view>
              <view class="stat-item">
                <text class="stat-icon">❤</text>
                <text class="stat-num">{{formatPlayCount(item.like_count)}}</text>
              </view>
            </view>
          </view>
          
          <view class="dialect-footer">
            <view class="collector-info">
              <image class="collector-avatar" src="{{(item.collector && item.collector.avatar) || '/images/default-avatar.png'}}" mode="aspectFill"/>
              <text class="collector-name">{{(item.collector && item.collector.nickname) || '志愿者'}}</text>
            </view>
            <text class="create-time">{{formatTimeAgo(item.created_at)}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{dialects.length === 0 && !loading}}">
      <view class="empty-icon">🎙️</view>
      <text class="empty-text">暂无方言录音</text>
      <text class="empty-subtext">点击下方按钮添加第一条方言</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{dialects.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{noMore}}">没有更多了</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </view>

  <!-- 创建按钮 -->
  <view class="create-btn-wrapper">
    <view class="create-btn {{animateCreateBtn ? 'animate' : ''}}" bindtap="goToCreate">
      <view class="create-icon">+</view>
      <text class="create-text">录方言</text>
    </view>
  </view>
</view>
