/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 60rpx;
}

/* 录音区域 */
.record-section {
  background: linear-gradient(135deg, #e67e22, #d35400);
  padding: 40rpx 30rpx 60rpx;
  position: relative;
}

/* 录音波形动画 */
.record-wave {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
  margin-bottom: 30rpx;
  gap: 6rpx;
}

.wave-bar {
  width: 6rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 3rpx;
  animation: wave 1s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { height: 20rpx; }
  50% { height: 60rpx; }
}

/* 录音状态 */
.record-status {
  text-align: center;
  margin-bottom: 30rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status-text.recording {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.status-hint {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 播放进度 */
.play-progress-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.play-slider {
  margin: 0;
}

.play-time {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 录音控制按钮 */
.record-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.control-btn.primary {
  position: relative;
}

.control-btn.secondary {
  opacity: 0.9;
}

.control-btn.secondary.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.control-btn.placeholder {
  width: 120rpx;
}

.btn-main {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.control-btn.recording .btn-main {
  background: rgba(255, 255, 255, 0.9);
  animation: pulse-ring 1.5s infinite;
}

@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); }
  50% { box-shadow: 0 0 0 20rpx rgba(255, 255, 255, 0); }
}

.icon-record {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e74c3c;
}

.icon-stop {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: #e74c3c;
}

.icon-play {
  width: 0;
  height: 0;
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
  border-left: 36rpx solid #e67e22;
  margin-left: 8rpx;
}

.icon-play.playing {
  width: 40rpx;
  height: 50rpx;
  border: none;
  display: flex;
  gap: 12rpx;
  margin-left: 0;
}

.icon-play.playing::before,
.icon-play.playing::after {
  content: '';
  width: 10rpx;
  height: 50rpx;
  background: #e67e22;
  border-radius: 5rpx;
}

.btn-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
}

.btn-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.label-required {
  font-size: 30rpx;
  color: #e74c3c;
  margin-left: 8rpx;
}

.label-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.form-input, .form-textarea {
  width: 100%;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  height: 160rpx;
  line-height: 1.6;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 选择器 */
.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-box.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 标签输入 */
.tag-input-box {
  display: flex;
  gap: 16rpx;
}

.tag-input {
  flex: 1;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tag-add-btn {
  padding: 20rpx 40rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #999;
}

.tag-add-btn.active {
  background: #e67e22;
  color: #fff;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(230, 126, 34, 0.1);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #e67e22;
}

.tag-remove {
  font-size: 32rpx;
  color: #e67e22;
  margin-left: 8rpx;
}

.popular-tags {
  margin-top: 20rpx;
}

.popular-title {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.popular-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.popular-tag {
  padding: 12rpx 24rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.popular-tag.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 走失人员选择 */
.selected-person {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.person-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #e0e0e0;
}

.person-info {
  flex: 1;
}

.person-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.person-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.person-remove {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.person-select-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
}

.select-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e67e22;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  margin-right: 16rpx;
}

.select-text {
  font-size: 28rpx;
  color: #e67e22;
}

/* 提交按钮 */
.submit-section {
  padding: 0 30rpx;
  text-align: center;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #e67e22, #d35400);
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
}

.submit-btn.loading {
  opacity: 0.8;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top: 4rpx solid #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.submit-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 走失人员选择弹窗 */
.mp-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.mp-picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
}

.mp-picker-popup.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 10rpx;
}

.picker-list {
  max-height: 60vh;
  padding: 20rpx 0;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
}

.picker-item:active {
  background: #f5f7fa;
}

.picker-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #e0e0e0;
}

.picker-info {
  flex: 1;
}

.picker-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.picker-region {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.picker-empty {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #999;
}
