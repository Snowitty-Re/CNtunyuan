/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.region-picker {
  flex-shrink: 0;
}

.picker-content {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #f5f7fa;
  border-radius: 32rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.picker-arrow {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #999;
}

.filter-info {
  font-size: 26rpx;
  color: #999;
}

.filter-count {
  color: #666;
}

/* 方言列表 */
.dialect-list {
  padding: 20rpx;
}

/* 方言卡片 */
.dialect-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 播放区域 */
.play-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e67e22, #d35400);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(230, 126, 34, 0.3);
  transition: all 0.2s ease;
}

.play-btn:active {
  transform: scale(0.95);
}

.play-btn.playing {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.play-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-play {
  width: 0;
  height: 0;
  border-top: 18rpx solid transparent;
  border-bottom: 18rpx solid transparent;
  border-left: 30rpx solid #fff;
  margin-left: 8rpx;
}

.icon-pause {
  display: flex;
  gap: 8rpx;
}

.pause-bar {
  width: 8rpx;
  height: 32rpx;
  background: #fff;
  border-radius: 4rpx;
}

.duration {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* 内容区域 */
.content-section {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dialect-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.dialect-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-tag {
  font-size: 22rpx;
  color: #e67e22;
  background: rgba(230, 126, 34, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.dialect-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dialect-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.dialect-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.meta-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 24rpx;
  color: #999;
  margin-right: 6rpx;
}

.stat-num {
  font-size: 24rpx;
  color: #999;
}

.dialect-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f2f5;
}

.collector-info {
  display: flex;
  align-items: center;
}

.collector-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #f0f2f5;
}

.collector-name {
  font-size: 24rpx;
  color: #666;
}

.create-time {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 创建按钮 */
.create-btn-wrapper {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 1000;
}

.create-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #e67e22, #d35400);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.4);
  transition: transform 0.2s ease;
}

.create-btn:active {
  transform: scale(0.9);
}

.create-btn.animate {
  animation: btnClick 0.2s ease;
}

@keyframes btnClick {
  0% { transform: scale(1); }
  50% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

.create-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.create-text {
  font-size: 22rpx;
  color: #fff;
  margin-top: 4rpx;
}
