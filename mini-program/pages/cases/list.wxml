<view class="container">
  <!-- 搜索和筛选栏 -->
  <view class="filter-bar">
    <!-- 搜索框 -->
    <view class="search-box">
      <text class="icon-search">🔍</text>
      <input 
        type="text" 
        placeholder="搜索姓名、地点..." 
        value="{{keyword}}" 
        bindinput="onSearchInput" 
        confirm-type="search" 
        bindconfirm="onSearch" 
      />
      <text class="search-btn" bindtap="onSearch" wx:if="{{keyword}}">搜索</text>
    </view>
    
    <!-- 状态筛选 -->
    <scroll-view scroll-x class="filter-tabs" enhanced show-scrollbar="{{false}}">
      <view 
        class="filter-tab {{currentStatus === item.value ? 'active' : ''}}" 
        wx:for="{{statusTabs}}" 
        wx:key="value"
        bindtap="switchStatus" 
        data-status="{{item.value}}"
      >
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <!-- 案件列表 -->
  <view class="case-list">
    <view 
      class="case-card" 
      wx:for="{{cases}}" 
      wx:key="id" 
      bindtap="goToDetail" 
      data-id="{{item.id}}"
    >
      <view class="case-header">
        <image class="case-photo" src="{{item.photoUrl}}" mode="aspectFill" lazy-load />
        <view class="case-info">
          <view class="case-title">
            <text class="case-name">{{item.name}}</text>
            <text class="case-age" wx:if="{{item.age}}">{{item.age}}岁</text>
          </view>
          <view class="case-tags">
            <text class="tag type-tag">{{caseTypeMap[item.case_type] || '其他'}}</text>
            <text class="tag status-tag" style="color: {{statusMap[item.status].color}}; background: {{statusMap[item.status].color}}20;">
              {{statusMap[item.status].label}}
            </text>
          </view>
          <view class="case-location">
            <text class="icon">📍</text>
            <text class="text">{{item.missing_location}}</text>
          </view>
          <view class="case-time">
            <text class="icon">📅</text>
            <text class="text">{{item.missing_time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{cases.length === 0 && !loading}}">
      <image class="empty-icon" src="/assets/images/empty.png" mode="aspectFit" />
      <text class="empty-text">暂无相关案件</text>
      <text class="empty-subtext">点击右下角按钮登记走失人员</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{cases.length > 0}}">
    <view class="loading" wx:if="{{loading}}">
      <text class="loading-dot"></text>
      <text class="loading-dot"></text>
      <text class="loading-dot"></text>
    </view>
    <text wx:elif="{{noMore}}" class="no-more">没有更多了</text>
    <text wx:else class="load-text" bindtap="loadMore">点击加载更多</text>
  </view>

  <!-- 新增按钮 -->
  <view class="fab-btn" bindtap="goToCreate">
    <text class="fab-icon">+</text>
  </view>
</view>
