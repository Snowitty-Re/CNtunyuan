.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 24rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.title-sub {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 12rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.required .label::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.form-item.vertical {
  flex-direction: column;
  align-items: flex-start;
  padding: 20rpx 0;
}

.form-item.vertical .label {
  margin-bottom: 16rpx;
}

.form-item.vertical textarea {
  width: 100%;
  height: 180rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-item input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2329;
  text-align: right;
}

.form-item input::placeholder {
  color: #999;
}

/* 选择器 */
.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #1f2329;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.picker-arrow {
  margin-left: 12rpx;
  font-size: 20rpx;
  color: #999;
}

/* 位置输入 */
.location-input {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.location-input input {
  flex: 1;
  text-align: right;
  margin-right: 16rpx;
}

.location-btn {
  font-size: 26rpx;
  color: #e67e22;
  padding: 8rpx 16rpx;
  background: #fff2e8;
  border-radius: 8rpx;
  white-space: nowrap;
}

.location-info {
  padding: 16rpx 0;
  margin-top: 16rpx;
  background: #f6ffed;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
}

.location-text {
  font-size: 26rpx;
  color: #52c41a;
}

/* 照片上传 */
.photo-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.delete-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-btn:active {
  border-color: #e67e22;
  background: #fff2e8;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.photo-tips {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fffbe6;
  border-radius: 8rpx;
}

.photo-tips text {
  font-size: 24rpx;
  color: #d48806;
}

/* 提交按钮 */
.form-actions {
  padding: 40rpx 0 calc(40rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 24rpx;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

.btn-reset {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.btn-reset::after {
  border: none;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
