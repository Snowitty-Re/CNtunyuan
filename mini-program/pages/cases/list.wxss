.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 44rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}

.icon-search {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-box input::placeholder {
  color: #999;
}

.search-btn {
  font-size: 26rpx;
  color: #e67e22;
  padding: 0 16rpx;
}

.filter-tabs {
  white-space: nowrap;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f7fa;
  border-radius: 32rpx;
  margin-right: 16rpx;
  transition: all 0.3s;
}

.filter-tab.active {
  background: #e67e22;
  color: #fff;
  font-weight: 500;
}

/* 案件列表 */
.case-list {
  padding: 0 24rpx;
}

.case-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.case-card:active {
  transform: scale(0.98);
}

.case-header {
  display: flex;
}

.case-photo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.case-info {
  flex: 1;
  min-width: 0;
}

.case-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.case-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2329;
  margin-right: 16rpx;
}

.case-age {
  font-size: 26rpx;
  color: #999;
}

.case-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.type-tag {
  background: #fff2e8;
  color: #e67e22;
}

.status-tag {
  font-weight: 500;
}

.case-location,
.case-time {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.case-location .icon,
.case-time .icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.case-location .text,
.case-time .text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: #e67e22;
  border-radius: 50%;
  animation: loading 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes loading {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.no-more {
  font-size: 26rpx;
  color: #999;
}

.load-text {
  font-size: 26rpx;
  color: #e67e22;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 新增按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f39c12, #e67e22);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(230, 126, 34, 0.4);
  z-index: 100;
}

.fab-btn:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}
