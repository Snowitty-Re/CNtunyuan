.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 24rpx 160rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 信息头部 */
.info-header {
  display: flex;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.person-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.person-info {
  flex: 1;
  min-width: 0;
}

.person-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 16rpx;
}

.person-age {
  font-size: 28rpx;
  color: #999;
  font-weight: normal;
  margin-left: 12rpx;
}

.person-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag.case-type {
  background: #fff2e8;
  color: #e67e22;
}

.tag.status.missing { background: #fff1f0; color: #ff4d4f; }
.tag.status.searching { background: #e6f7ff; color: #1890ff; }
.tag.status.found, .tag.status.reunited { background: #f6ffed; color: #52c41a; }
.tag.status.closed { background: #f5f5f5; color: #999; }

.case-no {
  font-size: 24rpx;
  color: #999;
}

/* 照片列表 */
.photo-section {
  margin-top: 24rpx;
}

.photo-scroll {
  white-space: nowrap;
}

.photo-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  display: inline-block;
  background: #f0f0f0;
}

/* 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.add-btn {
  font-size: 26rpx;
  color: #e67e22;
  padding: 8rpx 16rpx;
  background: #fff2e8;
  border-radius: 8rpx;
}

.nav-btn {
  font-size: 26rpx;
  color: #e67e22;
}

/* 信息列表 */
.info-list {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
}

.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #1f2329;
  text-align: right;
  word-break: break-all;
}

.info-value.text-primary {
  color: #e67e22;
}

/* 详情区域 */
.detail-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-section:first-child {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.detail-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.6;
}

/* 地图 */
.case-map {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

/* 轨迹 */
.track-list {
  padding-left: 20rpx;
  border-left: 2rpx solid #e8e8e8;
  margin-left: 16rpx;
}

.track-item {
  position: relative;
  padding-bottom: 32rpx;
  padding-left: 32rpx;
}

.track-item:last-child {
  padding-bottom: 0;
}

.track-dot {
  position: absolute;
  left: -27rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #e67e22;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #e67e22;
}

.track-content {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.track-location {
  font-size: 28rpx;
  color: #1f2329;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.track-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.track-time {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #999;
}

/* 管理者操作 */
.manager-actions .action-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action-btn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.action-btn-item:active {
  background: #f0f0f0;
}

.action-btn-item .btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-btn-item .btn-label {
  font-size: 24rpx;
  color: #666;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  background: #f5f7fa;
  color: #666;
}

.action-btn::after {
  border: none;
}

.action-btn.share {
  flex: 0.8;
}

.action-btn.phone {
  background: #e6f7ff;
  color: #1890ff;
}

.action-btn.primary {
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  flex: 1.2;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}
