<view class="container">
  <!-- 基本信息 -->
  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">👤</text>
      <text>基本信息</text>
    </view>
    
    <view class="form-item required">
      <text class="label">姓名</text>
      <input 
        placeholder="请输入走失人员姓名" 
        value="{{form.name}}" 
        bindinput="onInput" 
        data-field="name" 
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="0" bindchange="onGenderChange">
        <view class="picker-value">
          {{genderLabel}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">年龄</text>
      <input 
        type="digit" 
        placeholder="请输入年龄" 
        value="{{form.age}}" 
        bindinput="onNumberInput" 
        data-field="age" 
        maxlength="3"
      />
    </view>

    <view class="form-item">
      <text class="label">身高(cm)</text>
      <input 
        type="digit" 
        placeholder="请输入身高" 
        value="{{form.height}}" 
        bindinput="onNumberInput" 
        data-field="height" 
        maxlength="3"
      />
    </view>

    <view class="form-item required">
      <text class="label">案件类型</text>
      <picker mode="selector" range="{{caseTypeOptions}}" range-key="label" value="0" bindchange="onCaseTypeChange">
        <view class="picker-value">
          {{caseTypeLabel}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 走失信息 -->
  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📍</text>
      <text>走失信息</text>
    </view>
    
    <view class="form-item required">
      <text class="label">走失时间</text>
      <picker mode="multiSelector" value="{{dateTime}}" bindchange="onDateTimeChange" bindcolumnchange="onDateTimeColumnChange">
        <view class="picker-value">
          {{form.missingTime}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-item required">
      <text class="label">走失地点</text>
      <view class="location-input">
        <input 
          placeholder="请输入走失地点" 
          value="{{form.missingLocation}}" 
          bindinput="onInput" 
          data-field="missingLocation" 
        />
        <text class="location-btn" bindtap="chooseLocation">📍 地图</text>
      </view>
    </view>

    <!-- 已选择的位置信息 -->
    <view class="location-info" wx:if="{{form.latitude}}">
      <text class="location-text">已选择位置：{{form.missingLocation}}</text>
    </view>

    <view class="form-item vertical">
      <text class="label">走失描述</text>
      <textarea 
        placeholder="请详细描述走失经过、最后出现地点等信息" 
        value="{{form.description}}" 
        bindinput="onInput" 
        data-field="description" 
        maxlength="1000" 
        show-count
      />
    </view>
  </view>

  <!-- 外貌特征 -->
  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📝</text>
      <text>外貌特征</text>
    </view>

    <view class="form-item vertical">
      <text class="label">体貌特征</text>
      <textarea 
        placeholder="请描述走失人员的体貌特征，如脸型、发型、肤色、体型等" 
        value="{{form.appearance}}" 
        bindinput="onInput" 
        data-field="appearance" 
        maxlength="500" 
      />
    </view>

    <view class="form-item vertical">
      <text class="label">衣着描述</text>
      <textarea 
        placeholder="请描述走失时的穿着，包括衣服颜色、款式等" 
        value="{{form.clothing}}" 
        bindinput="onInput" 
        data-field="clothing" 
        maxlength="500" 
      />
    </view>

    <view class="form-item vertical">
      <text class="label">特殊特征</text>
      <textarea 
        placeholder="如有胎记、疤痕、残疾、口音等特殊情况请说明" 
        value="{{form.specialFeatures}}" 
        bindinput="onInput" 
        data-field="specialFeatures" 
        maxlength="500" 
      />
    </view>
  </view>

  <!-- 联系人信息 -->
  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📞</text>
      <text>联系人信息</text>
    </view>
    
    <view class="form-item">
      <text class="label">联系人</text>
      <input 
        placeholder="请输入联系人姓名" 
        value="{{form.contactName}}" 
        bindinput="onInput" 
        data-field="contactName" 
      />
    </view>

    <view class="form-item">
      <text class="label">关系</text>
      <input 
        placeholder="如：父亲、母亲、儿子等" 
        value="{{form.contactRelation}}" 
        bindinput="onInput" 
        data-field="contactRelation" 
      />
    </view>

    <view class="form-item required">
      <text class="label">联系电话</text>
      <input 
        type="number" 
        placeholder="请输入联系电话" 
        value="{{form.contactPhone}}" 
        bindinput="onInput" 
        data-field="contactPhone" 
        maxlength="11"
      />
    </view>
  </view>

  <!-- 照片上传 -->
  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📷</text>
      <text>照片上传</text>
      <text class="title-sub">（最多9张）</text>
    </view>
    <view class="photo-upload">
      <view class="photo-item" wx:for="{{photos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" bindtap="previewPhoto" data-index="{{index}}" />
        <text class="delete-icon" bindtap="deletePhoto" data-index="{{index}}">×</text>
      </view>
      <view class="upload-btn" bindtap="choosePhoto" wx:if="{{photos.length < 9}}">
        <text class="upload-icon">+</text>
        <text class="upload-text">添加照片</text>
      </view>
    </view>
    <view class="photo-tips">
      <text>请上传走失人员近期清晰照片，有助于志愿者辨认</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="form-actions">
    <button class="btn-submit" bindtap="submit" disabled="{{submitting}}">
      <text wx:if="{{!submitting}}">提交登记</text>
      <text wx:else>提交中...</text>
    </button>
    <button class="btn-reset" bindtap="resetForm" disabled="{{submitting}}">重置</button>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area-bottom"></view>
</view>
