<view class="container">
  <!-- 基本信息卡片 -->
  <view class="card">
    <view class="info-header">
      <image class="person-photo" src="{{caseData.photoUrl}}" mode="aspectFill" bindtap="previewImage" data-url="{{caseData.photoUrl}}" />
      <view class="person-info">
        <view class="person-name">
          {{caseData.name}} 
          <text class="person-age" wx:if="{{caseData.age}}">{{caseData.age}}岁</text>
        </view>
        <view class="person-tags">
          <text class="tag case-type">{{caseTypeMap[caseData.case_type] || '其他'}}</text>
          <text class="tag status {{caseData.status}}">{{statusMap[caseData.status]?.label || '未知'}}</text>
        </view>
        <view class="case-no">案件编号：{{caseData.case_no || caseData.id}}</view>
      </view>
    </view>

    <!-- 照片列表 -->
    <view class="photo-section" wx:if="{{caseData.photos && caseData.photos.length > 1}}">
      <scroll-view scroll-x class="photo-scroll">
        <image 
          wx:for="{{caseData.photos}}" 
          wx:key="id" 
          class="photo-item" 
          src="{{item.url || item}}" 
          mode="aspectFill" 
          bindtap="previewImage" 
          data-url="{{item.url || item}}" 
        />
      </scroll-view>
    </view>
  </view>

  <!-- 走失信息 -->
  <view class="card">
    <view class="section-title">走失信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">走失时间</text>
        <text class="info-value">{{caseData.missing_time}}</text>
      </view>
      <view class="info-item" bindtap="openLocation">
        <text class="info-label">走失地点</text>
        <text class="info-value text-primary">{{caseData.missing_location}} 📍</text>
      </view>
      <view class="info-item">
        <text class="info-label">性别</text>
        <text class="info-value">{{genderMap[caseData.gender] || '未知'}}</text>
      </view>
      <view class="info-item" wx:if="{{caseData.height}}">
        <text class="info-label">身高</text>
        <text class="info-value">{{caseData.height}}cm</text>
      </view>
      <view class="info-item" wx:if="{{caseData.possible_location}}">
        <text class="info-label">可能去向</text>
        <text class="info-value">{{caseData.possible_location}}</text>
      </view>
    </view>

    <!-- 走失详情 -->
    <view class="detail-section" wx:if="{{caseData.missing_detail}}">
      <view class="detail-title">走失详情</view>
      <view class="detail-content">{{caseData.missing_detail}}</view>
    </view>
  </view>

  <!-- 外貌特征 -->
  <view class="card" wx:if="{{caseData.appearance || caseData.clothing || caseData.special_features}}">
    <view class="section-title">外貌特征</view>
    <view class="detail-section" wx:if="{{caseData.appearance}}">
      <view class="detail-title">体貌特征</view>
      <view class="detail-content">{{caseData.appearance}}</view>
    </view>
    <view class="detail-section" wx:if="{{caseData.clothing}}">
      <view class="detail-title">衣着描述</view>
      <view class="detail-content">{{caseData.clothing}}</view>
    </view>
    <view class="detail-section" wx:if="{{caseData.special_features}}">
      <view class="detail-title">特殊特征</view>
      <view class="detail-content">{{caseData.special_features}}</view>
    </view>
  </view>

  <!-- 地图位置 -->
  <view class="card" wx:if="{{caseData.missing_latitude}}">
    <view class="section-header" bindtap="openLocation">
      <view class="section-title">走失地点位置</view>
      <text class="nav-btn">导航 ></text>
    </view>
    <map 
      class="case-map" 
      latitude="{{caseData.missing_latitude}}" 
      longitude="{{caseData.missing_longitude}}" 
      markers="{{markers}}" 
      scale="14" 
      show-location 
      bindtap="openLocation"
    />
  </view>

  <!-- 联系人信息 -->
  <view class="card">
    <view class="section-title">联系人信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">联系人</text>
        <text class="info-value">{{caseData.contact_name || '未知'}} {{caseData.contact_relation ? '(' + caseData.contact_relation + ')' : ''}}</text>
      </view>
      <view class="info-item" bindtap="makePhoneCall">
        <text class="info-label">联系电话</text>
        <text class="info-value text-primary">{{caseData.contact_phone || '暂无'}} 📞</text>
      </view>
      <view class="info-item" wx:if="{{caseData.contact_address}}">
        <text class="info-label">联系地址</text>
        <text class="info-value">{{caseData.contact_address}}</text>
      </view>
    </view>
  </view>

  <!-- 轨迹记录 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">轨迹记录</view>
      <text class="add-btn" bindtap="addTrack">+ 添加轨迹</text>
    </view>
    <view class="track-list" wx:if="{{tracks.length > 0}}">
      <view class="track-item" wx:for="{{tracks}}" wx:key="id">
        <view class="track-dot"></view>
        <view class="track-content">
          <view class="track-location">📍 {{item.location}}</view>
          <view class="track-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="track-time">{{item.track_time}} · {{item.reporter?.nickname || '志愿者'}}</view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text class="empty-icon">📍</text>
      <text class="empty-text">暂无轨迹记录</text>
      <text class="empty-subtext">发现线索请添加轨迹</text>
    </view>
  </view>

  <!-- 管理者操作区 -->
  <view class="card manager-actions" wx:if="{{isManager}}">
    <view class="section-title">管理操作</view>
    <view class="action-btns">
      <view class="action-btn-item" bindtap="updateStatus">
        <text class="btn-icon">📝</text>
        <text class="btn-label">更新状态</text>
      </view>
      <view class="action-btn-item" bindtap="markFound" wx:if="{{caseData.status !== 'found' && caseData.status !== 'reunited'}}">
        <text class="btn-icon">✓</text>
        <text class="btn-label">标记已找到</text>
      </view>
      <view class="action-btn-item" bindtap="markReunited" wx:if="{{caseData.status !== 'reunited'}}">
        <text class="btn-icon">🏠</text>
        <text class="btn-label">标记已团圆</text>
      </view>
      <view class="action-btn-item" bindtap="editCase">
        <text class="btn-icon">✏️</text>
        <text class="btn-label">编辑案件</text>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <button class="action-btn share" open-type="share">
      <text class="btn-icon">↗️</text>
      <text class="btn-text">分享</text>
    </button>
    <button class="action-btn phone" bindtap="makePhoneCall" wx:if="{{caseData.contact_phone}}">
      <text class="btn-icon">📞</text>
      <text class="btn-text">联系家属</text>
    </button>
    <button class="action-btn primary" bindtap="addTrack">
      <text class="btn-icon">📍</text>
      <text class="btn-text">添加线索</text>
    </button>
  </view>
</view>
