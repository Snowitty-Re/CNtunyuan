<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"></image>
    <text class="app-name">团圆寻亲</text>
    <text class="app-slogan">用爱点亮回家的路</text>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-tabs" wx:if="{{!isBinding}}">
    <view 
      class="tab-item {{loginType === 'wechat' ? 'active' : ''}}"
      data-type="wechat"
      bindtap="switchLoginType"
    >
      微信登录
    </view>
    <view 
      class="tab-item {{loginType === 'phone' ? 'active' : ''}}"
      data-type="phone"
      bindtap="switchLoginType"
    >
      账号登录
    </view>
  </view>

  <!-- 微信登录 -->
  <view class="login-form" wx:if="{{loginType === 'wechat' && !isBinding}}">
    <button 
      class="wechat-login-btn"
      type="primary"
      open-type="getPhoneNumber"
      bind:getphonenumber="handleWechatLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      <text class="wechat-icon">&#xe609;</text>
      <text>微信一键登录</text>
    </button>
    
    <view class="tips">
      <text class="tip-text">登录即表示您同意</text>
      <text class="link" bindtap="goToAgreement">《用户协议》</text>
      <text class="tip-text">和</text>
      <text class="link" bindtap="goToPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 手机号登录/绑定 -->
  <view class="login-form" wx:if="{{loginType === 'phone' || isBinding}}">
    <!-- 绑定提示 -->
    <view class="binding-tips" wx:if="{{isBinding}}">
      <text class="binding-icon">&#xe6a8;</text>
      <text class="binding-text">请先绑定手机号以继续使用</text>
    </view>

    <!-- 手机号输入 -->
    <view class="input-group">
      <text class="input-icon">&#xe6a1;</text>
      <input 
        type="number"
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 验证码输入 -->
    <view class="input-group" wx:if="{{isBinding}}">
      <text class="input-icon">&#xe6a3;</text>
      <input 
        type="number"
        placeholder="请输入验证码"
        maxlength="6"
        value="{{smsCode}}"
        bindinput="onCodeInput"
      />
      <button 
        class="code-btn {{canSendCode ? 'active' : ''}}"
        bindtap="sendVerifyCode"
        disabled="{{!canSendCode || counting}}"
      >
        {{counting ? countDown + 's' : '获取验证码'}}
      </button>
    </view>

    <!-- 密码输入 -->
    <view class="input-group" wx:if="{{!isBinding}}">
      <text class="input-icon">&#xe6a2;</text>
      <input 
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 登录按钮 -->
    <button 
      class="submit-btn"
      type="primary"
      bindtap="handlePhoneLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{isBinding ? '绑定手机号' : '登录'}}
    </button>

    <!-- 忘记密码 -->
    <view class="extra-links" wx:if="{{!isBinding}}">
      <text class="link" bindtap="goToRegister">注册账号</text>
      <text class="divider">|</text>
      <text class="link" bindtap="goToForgot">忘记密码</text>
    </view>

    <!-- 返回微信登录 -->
    <view class="back-wechat" wx:if="{{isBinding}}">
      <text bindtap="backToWechatLogin">← 返回微信登录</text>
    </view>
  </view>

  <!-- 底部版权 -->
  <view class="footer">
    <text>© 2024 团圆寻亲志愿者系统</text>
  </view>
</view>
