.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890ff 0%, #40a9ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.login-tip {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.login-tip .iconfont {
  font-size: 36rpx;
  color: #07c160;
}

.form-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
  margin-bottom: 20rpx;
}

.form-item .iconfont {
  font-size: 36rpx;
  color: #999;
}

.form-item input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.login-btn.wechat {
  background: #07c160;
}

.login-btn.primary {
  background: #1890ff;
}

.login-btn .iconfont {
  font-size: 40rpx;
}

.switch-type {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #1890ff;
}

.login-footer {
  margin-top: auto;
  padding-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-footer .link {
  color: #fff;
  text-decoration: underline;
}
