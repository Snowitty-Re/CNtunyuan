/* 登录页面样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF8C42 0%, #FF6B35 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 30rpx;
  background: #fff;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.tab-item {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 20rpx 40rpx;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #fff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* 登录表单 */
.login-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
}

/* 绑定提示 */
.binding-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF7E6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.binding-icon {
  font-size: 36rpx;
  color: #FF8C42;
  margin-right: 16rpx;
}

.binding-text {
  font-size: 28rpx;
  color: #FF8C42;
}

/* 输入框组 */
.input-group {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
}

.input-icon {
  font-size: 40rpx;
  color: #999;
  margin-right: 20rpx;
}

.input-group input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.input-group input::placeholder {
  color: #999;
}

/* 验证码按钮 */
.code-btn {
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  color: #999;
  background: #E8E8E8;
  border-radius: 8rpx;
  padding: 0;
  margin: 0;
}

.code-btn.active {
  color: #fff;
  background: #FF8C42;
}

/* 微信登录按钮 */
.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  border-radius: 12rpx;
  height: 96rpx;
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-top: 20rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.7;
}

/* 提示文字 */
.tips {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.tip-text {
  color: #999;
}

.link {
  color: #FF8C42;
}

/* 额外链接 */
.extra-links {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx;
  font-size: 28rpx;
}

.divider {
  color: #DDD;
  margin: 0 20rpx;
}

/* 返回微信登录 */
.back-wechat {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #999;
}

/* 底部版权 */
.footer {
  margin-top: auto;
  padding-bottom: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
