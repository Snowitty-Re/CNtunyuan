.notification-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
}

.unread-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.unread-count {
  font-size: 40rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.unread-text {
  font-size: 28rpx;
  color: #666;
}

.mark-all-btn {
  font-size: 28rpx;
  color: #1890ff;
  padding: 12rpx 24rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
}

.notification-list {
  padding: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.notification-item.unread {
  background: #f0f7ff;
}

.unread-dot {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
}

.icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-wrap.type-system {
  background: #e6f7ff;
  color: #1890ff;
}

.icon-wrap.type-task {
  background: #f6ffed;
  color: #52c41a;
}

.icon-wrap.type-case {
  background: #fff7e6;
  color: #faad14;
}

.icon-wrap.type-workflow {
  background: #f9f0ff;
  color: #722ed1;
}

.icon-wrap .iconfont {
  font-size: 40rpx;
}

.content {
  flex: 1;
  min-width: 0;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.type-tag {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  color: #1890ff;
  padding: 8rpx 16rpx;
  white-space: nowrap;
}

.action-btn.delete {
  color: #ff4d4f;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.load-more,
.no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
