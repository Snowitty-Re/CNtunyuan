.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 30rpx;
}

.action-text {
  font-size: 26rpx;
  color: #FF8C42;
}

.notification-list {
  padding: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.notification-item.unread {
  background: #FFF7E6;
}

.notification-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notification-icon.type-task {
  background: #E6F4FF;
  color: #1890FF;
}

.notification-icon.type-case {
  background: #FFF7E6;
  color: #FF8C42;
}

.notification-icon.type-system {
  background: #F0F0F0;
  color: #666;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.notification-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF4D4F;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.delete-btn {
  font-size: 40rpx;
  color: #ccc;
  padding: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #ddd;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
}
