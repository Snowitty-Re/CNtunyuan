<view class="container">
  <view class="header">
    <text class="header-title">消息通知</text>
    <view class="header-actions">
      <text class="action-text" bindtap="markAllAsRead">全部已读</text>
      <text class="action-text" bindtap="clearAll">清空</text>
    </view>
  </view>

  <view class="notification-list">
    <block wx:if="{{notifications.length > 0}}">
      <view 
        class="notification-item {{item.is_read ? 'read' : 'unread'}}"
        wx:for="{{notifications}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onNotificationTap"
      >
        <view class="notification-icon type-{{item.type}}">
          <text wx:if="{{item.type === 'task'}}">&#xe6b6;</text>
          <text wx:if="{{item.type === 'case'}}">&#xe6b7;</text>
          <text wx:if="{{item.type === 'system'}}">&#xe6b8;</text>
        </view>
        <view class="notification-content">
          <view class="notification-header">
            <text class="notification-title">{{item.title}}</text>
            <text class="notification-time">{{item.created_at}}</text>
          </view>
          <text class="notification-desc">{{item.content}}</text>
        </view>
        <view class="notification-status">
          <view class="unread-dot" wx:if="{{!item.is_read}}"></view>
          <text 
            class="delete-btn"
            data-id="{{item.id}}"
            catchtap="deleteNotification"
          >×</text>
        </view>
      </view>
    </block>
    
    <view class="empty-state" wx:else>
      <text class="empty-icon">&#xe6b9;</text>
      <text class="empty-text">暂无通知</text>
    </view>
  </view>

  <view class="load-more" wx:if="{{notifications.length > 0}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">没有更多了</text>
  </view>
</view>
