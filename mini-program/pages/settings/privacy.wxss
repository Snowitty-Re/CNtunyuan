.container {
  min-height: 100vh;
  background: #fff;
  padding: 40rpx;
}

.content {
  line-height: 1.8;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.text-content {
  display: block;
  font-size: 28rpx;
  color: #666;
  white-space: pre-wrap;
}
