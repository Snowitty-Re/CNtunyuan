.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  padding: 80rpx 40rpx;
  text-align: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 30rpx;
  background: #fff;
  margin-bottom: 30rpx;
}

.app-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.version {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.intro-section {
  background: #fff;
  padding: 40rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.features-section {
  background: #fff;
  padding: 40rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.feature-item {
  text-align: center;
  padding: 30rpx 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 56rpx;
  color: #FF8C42;
  margin-bottom: 16rpx;
  display: block;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-section {
  padding: 40rpx;
}

.update-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.update-btn::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 40rpx;
}

.footer text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}
