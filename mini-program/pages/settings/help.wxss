.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.page-header {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.faq-section {
  padding: 20rpx;
}

.faq-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.faq-question {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.q-mark {
  width: 40rpx;
  height: 40rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.question-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(180deg);
}

.faq-answer {
  display: flex;
  padding: 0 30rpx 30rpx;
  background: #fafafa;
}

.a-mark {
  width: 40rpx;
  height: 40rpx;
  background: #52C41A;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.answer-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.contact-section {
  padding: 60rpx 40rpx;
  text-align: center;
}

.contact-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
  display: block;
}

.contact-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF8C42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.contact-btn::after {
  border: none;
}
