.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.page-header {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.settings-list {
  padding: 20rpx;
}

.setting-group {
  margin-bottom: 20rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 30rpx;
}

.group-items {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 40rpx;
  color: #FF8C42;
  margin-right: 20rpx;
}

.item-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.item-extra {
  display: flex;
  align-items: center;
}

.cache-size {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-section {
  padding: 60rpx 40rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF4D4F;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.logout-btn::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 40rpx;
}

.footer text {
  font-size: 24rpx;
  color: #999;
}
