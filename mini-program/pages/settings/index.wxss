.settings-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  margin-bottom: 20rpx;
}

.user-card .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  flex: 1;
}

.user-info .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-info .phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-card .icon-arrow-right {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 30rpx;
}

.menu-list {
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  color: #1890ff;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-extra {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-extra .version {
  font-size: 26rpx;
  color: #999;
}

.icon-arrow-right {
  font-size: 28rpx;
  color: #ccc;
}

.logout-section {
  padding: 40rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}
