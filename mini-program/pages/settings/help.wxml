<view class="container">
  <view class="page-header">
    <text class="page-title">帮助中心</text>
  </view>

  <view class="faq-section">
    <view 
      class="faq-item"
      wx:for="{{faqList}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="toggleFaq"
    >
      <view class="faq-question">
        <text class="q-mark">Q</text>
        <text class="question-text">{{item.question}}</text>
        <text class="arrow {{item.expanded ? 'up' : ''}}">▼</text>
      </view>
      <view class="faq-answer" wx:if="{{item.expanded}}">
        <text class="a-mark">A</text>
        <text class="answer-text">{{item.answer}}</text>
      </view>
    </view>
  </view>

  <view class="contact-section">
    <text class="contact-title">还有其他问题？</text>
    <button class="contact-btn" bindtap="contactService">联系客服</button>
  </view>
</view>
