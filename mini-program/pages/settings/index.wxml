<view class="container">
  <view class="page-header">
    <text class="page-title">设置</text>
  </view>

  <view class="settings-list">
    <view class="setting-group" wx:for="{{settings}}" wx:key="group">
      <view class="group-title">{{item.group}}</view>
      <view class="group-items">
        <view 
          class="setting-item"
          wx:for="{{item.items}}"
          wx:for-item="setting"
          wx:key="title"
          data-item="{{setting}}"
          bindtap="onSettingTap"
        >
          <text class="item-icon">{{setting.icon}}</text>
          <text class="item-title">{{setting.title}}</text>
          <view class="item-extra">
            <text wx:if="{{setting.key === 'clearCache'}}" class="cache-size">{{cacheSize}}</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <view class="footer">
    <text>团圆寻亲志愿者系统 v1.0.0</text>
  </view>
</view>
