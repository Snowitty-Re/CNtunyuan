/* 地图页面样式 */
.map-container {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100%;
}

/* 搜索栏 */
.search-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}

.search-input-group {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 36rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  width: 100rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 26rpx;
  color: #fff;
  background: #FF8C42;
  border-radius: 28rpx;
  padding: 0;
  margin: 0;
}

.search-btn::after {
  border: none;
}

/* 筛选栏 */
.filter-bar {
  position: absolute;
  top: 120rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.filter-item.active {
  background: #FF8C42;
  color: #fff;
}

/* 定位按钮 */
.locate-btn {
  position: absolute;
  right: 20rpx;
  bottom: 300rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.locate-icon {
  font-size: 40rpx;
  color: #FF8C42;
}

/* 刷新按钮 */
.refresh-btn {
  position: absolute;
  right: 20rpx;
  bottom: 200rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.refresh-btn.loading {
  animation: rotate 1s linear infinite;
}

.refresh-icon {
  font-size: 40rpx;
  color: #666;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 案件面板 */
.case-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 200;
  max-height: 70vh;
}

.case-panel.show {
  transform: translateY(0);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.panel-count {
  font-size: 26rpx;
  color: #999;
  margin-left: 10rpx;
}

.panel-close {
  font-size: 40rpx;
  color: #999;
}

.case-list {
  max-height: 60vh;
  padding: 20rpx;
}

.case-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.case-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.case-info {
  flex: 1;
  min-width: 0;
}

.case-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.case-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.case-status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-missing {
  background: #FFE5E5;
  color: #FF4D4F;
}

.status-searching {
  background: #FFF7E6;
  color: #FF8C42;
}

.status-found {
  background: #E6F7E6;
  color: #52C41A;
}

.status-reunited {
  background: #E6F4FF;
  color: #1890FF;
}

.case-location {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.location-icon {
  font-size: 24rpx;
  color: #999;
  margin-right: 6rpx;
}

.location-text {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-time {
  font-size: 24rpx;
  color: #999;
}

.case-actions {
  margin-left: 20rpx;
}

.action-btn.navigate {
  background: #FF8C42;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.action-btn.navigate::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #ddd;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 40rpx;
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: #FF8C42;
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #FF8C42;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
