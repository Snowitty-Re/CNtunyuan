<view class="map-container">
  <!-- 地图 -->
  <map
    id="map"
    class="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    show-location
    show-compass
    enable-zoom
    enable-scroll
    enable-rotate
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
    bindregionchange="onRegionChange"
  ></map>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-group">
      <text class="search-icon">&#xe6a0;</text>
      <input 
        class="search-input"
        type="text"
        placeholder="搜索案件名称或地点"
        value="{{keyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{status === '' ? 'active' : ''}}"
      data-status=""
      bindtap="onStatusChange"
    >全部</view>
    <view 
      class="filter-item {{status === 'missing' ? 'active' : ''}}"
      data-status="missing"
      bindtap="onStatusChange"
    >失踪中</view>
    <view 
      class="filter-item {{status === 'searching' ? 'active' : ''}}"
      data-status="searching"
      bindtap="onStatusChange"
    >寻找中</view>
    <view 
      class="filter-item {{status === 'found' ? 'active' : ''}}"
      data-status="found"
      bindtap="onStatusChange"
    >已找到</view>
  </view>

  <!-- 定位按钮 -->
  <view class="locate-btn" bindtap="locateCurrentPosition">
    <text class="locate-icon">&#xe6a7;</text>
  </view>

  <!-- 刷新按钮 -->
  <view class="refresh-btn {{loading ? 'loading' : ''}}" bindtap="onRefresh">
    <text class="refresh-icon">&#xe6a6;</text>
  </view>

  <!-- 案件列表浮层 -->
  <view class="case-panel {{showCaseList ? 'show' : ''}}">
    <view class="panel-header" bindtap="hideCaseList">
      <view class="panel-title">
        案件列表
        <text class="panel-count">({{markers.length}})</text>
      </view>
      <text class="panel-close">&#xe6a5;</text>
    </view>
    
    <scroll-view class="case-list" scroll-y>
      <block wx:if="{{markers.length > 0}}">
        <view 
          class="case-item"
          wx:for="{{markers}}"
          wx:key="id"
          data-item="{{item.data}}"
          bindtap="goToCaseDetail"
          data-id="{{item.data.id}}"
        >
          <image 
            class="case-photo" 
            src="{{item.data.photos[0].url || '/assets/icons/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="case-info">
            <view class="case-header">
              <text class="case-name">{{item.data.name}}</text>
              <text class="case-status status-{{item.data.status}}">
                {{item.data.status_text}}
              </text>
            </view>
            <view class="case-location">
              <text class="location-icon">&#xe6a4;</text>
              <text class="location-text">{{item.data.last_seen_location || '未知位置'}}</text>
            </view>
            <view class="case-time">
              失踪时间：{{item.data.missing_time}}
            </view>
          </view>
          <view class="case-actions">
            <button 
              class="action-btn navigate"
              size="mini"
              data-item="{{item.data}}"
              catchtap="navigateToLocation"
            >导航</button>
          </view>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <text class="empty-icon">&#xe6a9;</text>
        <text class="empty-text">暂无案件数据</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="action-btn primary" bindtap="showCaseList">
      <text class="btn-icon">&#xe6aa;</text>
      <text>案件列表</text>
    </button>
    <button class="action-btn secondary" bindtap="goToCreateCase">
      <text class="btn-icon">&#xe6ab;</text>
      <text>发布案件</text>
    </button>
  </view>
</view>
