.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FDF8F3 100%);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Hero 区域 */
.hero-section {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.6;
}

.orb-1 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #FFB085 0%, #FF8C42 100%);
  top: -100rpx;
  right: -80rpx;
}

.orb-2 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #7EC8A0 0%, #5FB085 100%);
  bottom: 20rpx;
  left: -60rpx;
}

.orb-3 {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, #6B8E9F 0%, #4A6B7C 100%);
  top: 40rpx;
  left: 40%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.greeting {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.greeting-icon {
  font-size: 40rpx;
  animation: wave 2s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(20deg); }
  75% { transform: rotate(-10deg); }
}

.greeting-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.welcome-title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2D3436 0%, #636E72 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.welcome-subtitle {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 500;
  letter-spacing: 8rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.action-card {
  flex: 1;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx var(--shadow);
  transition: all 0.3s ease;
}

.action-card:active {
  transform: scale(0.98);
}

.action-card.primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
}

.action-card.primary .action-icon {
  background: rgba(255, 255, 255, 0.2);
}

.action-card.primary .action-title,
.action-card.primary .action-desc {
  color: #fff;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(255, 140, 66, 0.1) 0%, rgba(255, 176, 133, 0.1) 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon .iconfont {
  font-size: 40rpx;
  color: var(--primary);
}

.action-card.primary .action-icon .iconfont {
  color: #fff;
}

.action-text {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow);
  min-width: 200rpx;
}

.stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-icon.bg-orange {
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
}

.stat-icon.bg-green {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
}

.stat-icon.bg-blue {
  background: linear-gradient(135deg, #D6E8F0 0%, #C0DCE8 100%);
}

.stat-icon .iconfont {
  font-size: 36rpx;
}

.stat-icon.bg-orange .iconfont { color: var(--primary); }
.stat-icon.bg-green .iconfont { color: #27AE60; }
.stat-icon.bg-blue .iconfont { color: var(--secondary); }

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 区块 */
.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 4rpx;
}

.more-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.more-link .iconfont {
  font-size: 24rpx;
}

/* 案件卡片 */
.case-scroll {
  padding: 0 32rpx;
}

.case-list {
  display: flex;
  gap: 24rpx;
}

.case-card {
  width: 280rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--shadow);
  flex-shrink: 0;
  animation: slideUp 0.5s ease-out;
}

.case-image-wrapper {
  position: relative;
  height: 200rpx;
}

.case-image {
  width: 100%;
  height: 100%;
}

.case-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-xl);
  font-size: 22rpx;
  font-weight: 500;
}

.case-status.missing {
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
  color: var(--primary-dark);
}

.case-status.searching {
  background: linear-gradient(135deg, #FFF3CD 0%, #FFEAA7 100%);
  color: #F39C12;
}

.case-status.found {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
  color: #27AE60;
}

.case-info {
  padding: 20rpx;
}

.case-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.case-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.case-time {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 方言卡片 */
.recent-dialects {
  padding: 0 32rpx;
}

.dialect-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dialect-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 24rpx var(--shadow);
  animation: fadeIn 0.5s ease-out;
}

.dialect-play {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.3);
}

.play-btn .iconfont {
  font-size: 36rpx;
  color: #fff;
  margin-left: 4rpx;
}

.wave-animation {
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 40rpx;
}

.wave-bar {
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--primary-light) 0%, var(--primary) 100%);
  border-radius: 2rpx;
  animation: waveBar 1s ease-in-out infinite;
}

@keyframes waveBar {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1); }
}

.dialect-info {
  flex: 1;
  min-width: 0;
}

.dialect-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.dialect-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.dialect-stats {
  display: flex;
  gap: 24rpx;
}

.dialect-stats .stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.dialect-stats .iconfont {
  font-size: 24rpx;
}
