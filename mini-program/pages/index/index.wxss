/* 首页样式 - 温馨橙色主题 #FF8C42 */

.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FDF8F3 100%);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Hero 区域 ========== */
.hero-section {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
}

.orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  top: -150rpx;
  right: -100rpx;
}

.orb-2 {
  width: 250rpx;
  height: 250rpx;
  background: linear-gradient(135deg, #7EC8A0 0%, #5FB085 100%);
  bottom: 0;
  left: -80rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.greeting {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.greeting-icon {
  font-size: 36rpx;
  animation: wave 2s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(20deg); }
  75% { transform: rotate(-10deg); }
}

.greeting-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #FF8C42;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* ========== 快捷入口 ========== */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
}

.action-btn:active {
  opacity: 0.7;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.action-icon.primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
}

.action-icon.secondary {
  background: linear-gradient(135deg, #7EC8A0 0%, #5FB085 100%);
}

.action-icon.tertiary {
  background: linear-gradient(135deg, #6B8E9F 0%, #4A6B7C 100%);
}

.action-icon.quaternary {
  background: linear-gradient(135deg, #9B7ED8 0%, #7B5DB8 100%);
}

.action-icon .iconfont {
  font-size: 44rpx;
  color: #fff;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ========== 统计数据区域 ========== */
.stats-section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.update-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  min-width: 150rpx;
  max-width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.06);
}

.stat-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-icon.orange {
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
}

.stat-icon.green {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
}

.stat-icon.blue {
  background: linear-gradient(135deg, #D6E8F0 0%, #C0DCE8 100%);
}

.stat-icon.purple {
  background: linear-gradient(135deg, #EDE5F5 0%, #DDD0ED 100%);
}

.stat-icon .iconfont {
  font-size: 36rpx;
  line-height: 1;
}

.stat-icon.orange .iconfont { color: #FF8C42; }
.stat-icon.green .iconfont { color: #27AE60; }
.stat-icon.blue .iconfont { color: #6B8E9F; }
.stat-icon.purple .iconfont { color: #9B7ED8; }

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* ========== 内容区域通用样式 ========== */
.content-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.more-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #FF8C42;
  font-weight: 500;
}

.more-link:active {
  opacity: 0.7;
}

.more-link .iconfont {
  font-size: 22rpx;
}

/* ========== 案件列表 ========== */
.case-scroll {
  padding: 0 32rpx;
}

.case-list {
  display: flex;
  gap: 20rpx;
}

.case-card {
  width: 260rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.case-card:active {
  transform: scale(0.98);
}

.case-image-wrapper {
  position: relative;
  height: 180rpx;
}

.case-image {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
}

.case-status {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.case-status.missing {
  background: linear-gradient(135deg, #FFE5D9 0%, #FFD4C2 100%);
  color: #E67335;
}

.case-status.searching {
  background: linear-gradient(135deg, #FFF3CD 0%, #FFEAA7 100%);
  color: #F39C12;
}

.case-status.found {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
  color: #27AE60;
}

.case-status.reunited {
  background: linear-gradient(135deg, #D4F5E0 0%, #B8EDD0 100%);
  color: #27AE60;
}

.case-info {
  padding: 16rpx;
}

.case-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.case-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.case-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--background);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.case-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-location .iconfont {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-right: 4rpx;
}

.case-time {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* ========== 方言列表 ========== */
.dialect-list {
  padding: 0 32rpx;
}

.dialect-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.dialect-card:last-child {
  margin-bottom: 0;
}

.dialect-card:active {
  transform: scale(0.99);
  background: #fafafa;
}

.dialect-play {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.play-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 66, 0.3);
}

.play-btn .iconfont {
  font-size: 28rpx;
  color: #fff;
  margin-left: 4rpx;
}

.wave-animation {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 32rpx;
  width: 40rpx;
}

.wave-bar {
  width: 3rpx;
  height: 100%;
  background: linear-gradient(180deg, #FFB085 0%, #FF8C42 100%);
  border-radius: 2rpx;
  animation: waveBar 1.2s ease-in-out infinite;
}

@keyframes waveBar {
  0%, 100% { transform: scaleY(0.3); }
  50% { transform: scaleY(1); }
}

.dialect-info {
  flex: 1;
  min-width: 0;
}

.dialect-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.dialect-location {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.dialect-location .iconfont {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-right: 4rpx;
}

.dialect-stats {
  display: flex;
  gap: 20rpx;
}

.dialect-stats .stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.dialect-stats .stat-item .iconfont {
  font-size: 20rpx;
}

.dialect-stats .stat-item.time {
  margin-left: auto;
}

/* ========== 加载、错误、空状态 ========== */
.loading-state,
.error-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF8C42;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.error-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.retry-btn {
  font-size: 26rpx;
  color: #FF8C42;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border: 2rpx solid #FF8C42;
  border-radius: 30rpx;
}

.retry-btn:active {
  background: rgba(255, 140, 66, 0.1);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FFE5D9 0%, rgba(255, 176, 133, 0.2) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.empty-icon .iconfont {
  font-size: 60rpx;
  color: #FF8C42;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-action {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB085 100%);
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.empty-action:active {
  opacity: 0.9;
}

/* ========== 工具类 ========== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.safe-bottom {
  height: 40rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
