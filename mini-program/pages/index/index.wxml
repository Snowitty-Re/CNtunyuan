<view class="home-page">
  <!-- 顶部欢迎区 -->
  <view class="hero-section">
    <view class="hero-bg">
      <view class="gradient-orb orb-1"></view>
      <view class="gradient-orb orb-2"></view>
      <view class="gradient-orb orb-3"></view>
    </view>
    <view class="hero-content">
      <view class="greeting">
        <text class="greeting-icon">👋</text>
        <text class="greeting-text">{{greeting}}</text>
      </view>
      <view class="welcome-title">团圆寻亲</view>
      <view class="welcome-subtitle">用爱点亮回家路</view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-card primary" bindtap="goToCreateCase">
      <view class="action-icon">
        <text class="iconfont icon-add"></text>
      </view>
      <view class="action-text">
        <text class="action-title">登记走失</text>
        <text class="action-desc">帮助寻找亲人</text>
      </view>
    </view>
    <view class="action-card secondary" bindtap="goToRecordDialect">
      <view class="action-icon">
        <text class="iconfont icon-mic"></text>
      </view>
      <view class="action-text">
        <text class="action-title">录制方言</text>
        <text class="action-desc">助力寻亲</text>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stat-card">
      <view class="stat-icon bg-orange">
        <text class="iconfont icon-people"></text>
      </view>
      <view class="stat-info">
        <text class="stat-value">{{stats.totalCases}}</text>
        <text class="stat-label">寻亲案例</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon bg-green">
        <text class="iconfont icon-success"></text>
      </view>
      <view class="stat-info">
        <text class="stat-value">{{stats.resolvedCases}}</text>
        <text class="stat-label">成功团圆</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon bg-blue">
        <text class="iconfont icon-volunteer"></text>
      </view>
      <view class="stat-info">
        <text class="stat-value">{{stats.volunteers}}</text>
        <text class="stat-label">志愿者</text>
      </view>
    </view>
  </view>

  <!-- 最近案件 -->
  <view class="section recent-cases" wx:if="{{recentCases.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近案件</text>
      <view class="more-link" bindtap="goToCases">
        <text>查看更多</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
    <scroll-view class="case-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="case-list">
        <view class="case-card" wx:for="{{recentCases}}" wx:key="id" bindtap="goToCaseDetail" data-id="{{item.id}}">
          <view class="case-image-wrapper">
            <image class="case-image" src="{{item.photoUrl}}" mode="aspectFill" />
            <view class="case-status status-{{item.status}}">{{statusText[item.status]}}</view>
          </view>
          <view class="case-info">
            <text class="case-name">{{item.name}}</text>
            <text class="case-location">{{item.missingLocation}}</text>
            <text class="case-time">{{item.missingTime}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近方言 -->
  <view class="section recent-dialects" wx:if="{{recentDialects.length > 0}}">
    <view class="section-header">
      <text class="section-title">方言录音</text>
      <view class="more-link" bindtap="goToDialects">
        <text>查看更多</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
    <view class="dialect-list">
      <view class="dialect-card" wx:for="{{recentDialects}}" wx:key="id" bindtap="goToDialectDetail" data-id="{{item.id}}">
        <view class="dialect-play">
          <view class="play-btn">
            <text class="iconfont icon-play"></text>
          </view>
          <view class="wave-animation">
            <view class="wave-bar" wx:for="{{5}}" wx:key="*this" style="animation-delay: {{index * 0.1}}s"></view>
          </view>
        </view>
        <view class="dialect-info">
          <text class="dialect-title">{{item.title}}</text>
          <text class="dialect-location">{{item.province}} {{item.city}}</text>
          <view class="dialect-stats">
            <text class="stat-item">
              <text class="iconfont icon-play-count"></text>
              {{item.playCount}}
            </text>
            <text class="stat-item">
              <text class="iconfont icon-like"></text>
              {{item.likeCount}}
            </text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom" style="height: 40rpx;"></view>
</view>
