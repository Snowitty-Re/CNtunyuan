/**
 * Emoji 图标系统
 * 使用 Unicode Emoji 作为图标，无需外部字体文件
 */

/* 基础图标样式 */
.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-style: normal;
  line-height: 1;
}

/* iconfont 兼容层 - 将 iconfont 类名映射到 emoji */
.iconfont {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-style: normal;
  line-height: 1;
}

/* 图标映射表 */
