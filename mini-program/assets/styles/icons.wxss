/* 图标尺寸 */
.icon-xs { font-size: 20rpx; }
.icon-sm { font-size: 28rpx; }
.icon-md { font-size: 36rpx; }
.icon-lg { font-size: 48rpx; }
.icon-xl { font-size: 64rpx; }
.icon-xxl { font-size: 96rpx; }

/* Emoji 图标优化显示 */
.iconfont {
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 特殊图标样式 */
.icon-play::before,
.iconfont.icon-play::before { 
  content: "▶"; 
  font-size: 0.8em;
}

.icon-pause::before,
.iconfont.icon-pause::before { 
  content: "⏸"; 
  font-size: 0.8em;
}

/* 箭头图标优化 */
.icon-arrow-right::before,
.iconfont.icon-arrow-right::before {
  content: "›";
  font-weight: bold;
}

/* 空状态图标 */
.icon-empty::before,
.iconfont.icon-empty::before {
  content: "📭";
  opacity: 0.7;
}
